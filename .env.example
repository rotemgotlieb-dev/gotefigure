# GoteFigure backend — SECRET NAMES ONLY. Never commit real values.
# Real values live in the Cloudflare Pages env/secret store (prod) and .dev.vars (local, gitignored).
# See vault: [[Safe Backend Doctrine]] + [[GoteFigure Backend Plan]].
#
# Enable the secret-scan pre-commit hook once per clone:
#   git config core.hooksPath .githooks
#
# publishable vs secret (Doctrine principle 2):
#   PUBLIC  (may ship to the browser): Turnstile SITE key, Stripe pk_, analytics beacon token
#   SECRET  (server-only, never in client): everything listed below

# --- Sprint 1: email / notify-me capture ---
TURNSTILE_SECRET_KEY=       # Cloudflare Turnstile SECRET (server-side verification)
BUTTONDOWN_API_KEY=         # email vendor API key (server-side only)
# TURNSTILE_SITE_KEY is PUBLIC — set it as a public var, not a secret.
# The D1 binding (e.g. DB) is configured in wrangler / Pages, not via .env.

# --- Sprint 2: hard server-side gate (uncomment when built) ---
# GATE_PASSWORD=            # server-only; 32+ chars
# COOKIE_SIGNING_SECRET=    # server-only; 32+ chars; rotating it invalidates all sessions

# --- Sprint 3 ALTERNATIVE (custom Stripe path — only if chosen over Fourthwall) ---
# STRIPE_SECRET_KEY=        # rk_ / sk_  server-only
# STRIPE_WEBHOOK_SECRET=    # whsec_     server-only
# STRIPE_PUBLISHABLE_KEY is PUBLIC (pk_) — client-safe, do not store as a secret.
