# Public values only — real secrets are Worker secrets (`wrangler secret put NAME`)
# and local-dev values live in .dev.vars (gitignored). Never commit real values here.

# Turnstile PUBLIC sitekey (safe to expose; pairs with the server-side secret)
# NAME MATTERS: the code reads PUBLIC_TURNSTILE_SITEKEY (src/animations/after-hours.ts);
# the old PUBLIC_TURNSTILE_SITE_KEY spelling silently falls back to the TEST key = zero capture.
PUBLIC_TURNSTILE_SITEKEY=

# Commerce provider switch (docs/INVENTORY-RUNBOOK.md §6). Default mock; "fourthwall"
# additionally requires the storefront token below and catalog-lint's cutover guard to pass.
PUBLIC_COMMERCE_PROVIDER=mock
# PUBLIC_FW_STOREFRONT_TOKEN=
# PUBLIC_FW_CHECKOUT_DOMAIN=
# PUBLIC_FW_COLLECTION=all

# --- Worker secrets (names only, for reference) ---
# TURNSTILE_SECRET_KEY=   server-side Turnstile verification (/api/subscribe)
# GATE_CODE=              the store gate passphrase (server-only since Sprint 2; never in the bundle)
# GATE_SIGNING_KEY=       HMAC key for the gate cookie — 32+ random bytes, e.g. `openssl rand -hex 32`
# FW_WEBHOOK_SECRET=      Fourthwall webhook signing secret (S6; /api/orders/webhook verifies the RAW body with it)

# Optional plain var (a header NAME is not a secret): only set if Fourthwall's
# signature-verification doc names a different header than the code default.
# FW_WEBHOOK_SIG_HEADER=x-fourthwall-hmac-sha256
