---
// The story (§6.4): origin → dormant years owned → archive → the daily practice → now.
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import GlyphDust from '../components/GlyphDust.astro';
import SectionDivider from '../components/SectionDivider.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getVideos, thumb, watchUrl, CHANNEL_URL } from '../lib/youtube';
import { getPhoto } from '../lib/photos';

const videos = await getVideos();
const mainVideo = videos.find((v) => !v.short) ?? videos[0];
const shorts = videos.filter((v) => v.short).slice(0, 4);

const archive = [
  {
    photo: getPhoto('boatday-1'), date: 'summer 2020',
    caption: 'Lake day with the nine eyes 👀 — first batch almost gone!',
    comment: '“This is hella sick”',
  },
  {
    photo: getPhoto('alien-tee-duo-cliffs'), date: 'fall 2020',
    caption: 'Alien tee — front AND back print. Super dope and stylish 🛸',
    comment: '“need this immediately”',
  },
  {
    photo: getPhoto('trail-walk-duo'), date: 'summer 2021',
    caption: 'Sneak peak — ALL NEW DESIGNS DROPPING JULY 11th 8AM 🔥🔥',
    comment: '“taking my whole paycheck”',
  },
];
---
<Layout title="About — GoteFigure" description="An art-based clothing brand from California. Founded in lockdown 2020, dormant for a while, reborn in 2026 — drawing every day.">
  <article class="story">
    <GlyphDust seed={31} count={14} />

    <header class="story-hero">
      <h1>About<span class="accent">.</span></h1>
      <p class="lede">
        GoteFigure is one artist, one pen, and a stubborn belief that the stuff you wear
        should be <em>actual art</em> — drawn by a human hand, scribbles and all.
      </p>
    </header>

    <section class="chapter">
      <p class="chapter-year">2020</p>
      <h2>Born in lockdown</h2>
      <p>
        California, COVID spring. Nowhere to go, so the pen went everywhere — rabbits with
        googly eyes, aliens in saucers, mushrooms in stipple. Friends asked for shirts.
        Then friends of friends. GoteFigure became a real store with a mission that still
        holds: <em>unique wearable art, high quality goods, for people who love the niche.</em>
      </p>
      <figure class="chapter-art">
        <img src="/art/rabbit-cameo.webp" alt="The OG Rabbit — pink cameo artwork" loading="lazy" data-draw />
        <figcaption class="margin-note">the OG Rabbit, est. 2020</figcaption>
      </figure>
    </section>

    <section class="chapter chapter--archive" aria-labelledby="archive-title">
      <p class="chapter-year">2020–21</p>
      <h2 id="archive-title">The archive era</h2>
      <p>Boat days, drop announcements at 8AM sharp, everything sold out by December. Then life happened and the shop went quiet. We kept the receipts:</p>
      <div class="feed">
        {archive.map((post) => (
          <figure class="post">
            {post.photo && <Image src={post.photo} alt="" widths={[500]} sizes="(max-width: 700px) 90vw, 340px" class="post-img" loading="lazy" />}
            <figcaption>
              <p class="post-date">{post.date}</p>
              <p class="post-caption">{post.caption}</p>
              <p class="post-comment">{post.comment}</p>
            </figcaption>
          </figure>
        ))}
      </div>
      <p class="margin-note">captions preserved as posted — typos were free in 2020</p>
    </section>

    <SectionDivider color="var(--amber)" />

    <section class="chapter chapter--practice" aria-labelledby="practice-title">
      <p class="chapter-year">2026</p>
      <h2 id="practice-title">Drawing every day</h2>
      <p>
        The relaunch didn’t start with merch — it started with a practice. A drawing a day,
        filmed, posted, no skips. The art on this site comes straight out of that sketchbook.
      </p>

      <div class="practice-grid">
        <a href={watchUrl(mainVideo)} target="_blank" rel="noopener" class="main-video">
          <img src={thumb(mainVideo.id)} alt="" loading="lazy" width="640" height="480" />
          <span class="main-video-meta">
            <span class="yt-play" aria-hidden="true">▶</span>
            <span>{mainVideo.title}</span>
          </span>
        </a>
        <div class="shorts-rail">
          {shorts.map((s) => (
            <a href={watchUrl(s)} target="_blank" rel="noopener" class="short-card">
              <img src={thumb(s.id)} alt="" loading="lazy" width="320" height="240" />
              <span>{s.title}</span>
            </a>
          ))}
        </div>
      </div>
      <a class="squiggle practice-sub" href={`${CHANNEL_URL}?sub_confirmation=1`} target="_blank" rel="noopener">
        subscribe — watch the next piece happen
      </a>
    </section>

    <section class="chapter chapter--now">
      <h2>Why a store again?</h2>
      <p>
        Because people kept asking. Because posters deserve walls and art deserves bodies.
        Every apparel piece is printed to order; posters and stickers are printed locally in
        California and packed by the artist — margin notes included, literally.
      </p>
      <NewsletterForm context="about" />
    </section>
  </article>
</Layout>

<style>
  .story { position: relative; max-width: 880px; margin: 0 auto; padding: var(--s-12) var(--s-6) var(--s-24); }
  .story-hero h1 { margin-bottom: var(--s-4); }
  .accent { color: var(--amber); }
  .lede { font-size: var(--text-lg); max-width: 52ch; margin-bottom: var(--s-12); }

  .chapter { margin-bottom: var(--s-16); }
  .chapter-year { font-weight: 700; letter-spacing: 0.2em; font-size: var(--text-sm); color: var(--teal); }
  .chapter h2 { margin: var(--s-1) 0 var(--s-3); }
  .chapter p { max-width: 58ch; margin-bottom: var(--s-3); }
  .chapter-art { margin-top: var(--s-6); max-width: 300px; }
  .chapter-art img { width: 100%; }

  .feed { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-6); margin: var(--s-6) 0 var(--s-3); overflow: clip; padding: var(--s-1); }
  .post {
    border: 2px solid var(--ink); border-radius: 16px; overflow: hidden; background: var(--paper);
    transform: rotate(var(--tilt, -1deg));
  }
  .post:nth-child(2) { --tilt: 1.2deg; }
  .post:nth-child(3) { --tilt: -0.6deg; }
  .post-img { aspect-ratio: 1; object-fit: cover; width: 100%; }
  .post figcaption { padding: var(--s-3); }
  .post-date { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; color: color-mix(in srgb, var(--ink) 55%, var(--paper)); }
  .post-caption { font-size: var(--text-sm); margin: var(--s-1) 0; }
  .post-comment { font-size: var(--text-sm); font-style: italic; color: color-mix(in srgb, var(--og-pink) 70%, var(--ink)); }

  .practice-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: var(--s-6); margin: var(--s-6) 0; }
  .main-video { display: block; position: relative; border: 2px solid var(--ink); border-radius: 16px; overflow: hidden; }
  .main-video img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 4/3; }
  .main-video-meta {
    position: absolute; left: 0; right: 0; bottom: 0;
    display: flex; gap: var(--s-2); align-items: center;
    background: color-mix(in srgb, var(--ink) 82%, transparent); color: var(--paper);
    padding: var(--s-2) var(--s-3); font-size: var(--text-sm); font-weight: 600;
  }
  .yt-play { background: var(--paper); color: var(--ink); border-radius: 999px; width: 26px; height: 26px; display: grid; place-items: center; font-size: 10px; flex: none; }
  .shorts-rail { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-3); align-content: start; }
  .short-card { display: grid; gap: 4px; text-decoration: none; font-size: 0.78rem; font-weight: 600; min-width: 0; }
  .short-card img { border: 2px solid var(--ink); border-radius: 12px; aspect-ratio: 1; object-fit: cover; width: 100%; }
  .practice-sub { font-weight: 700; }

  @media (max-width: 700px) {
    .feed { grid-template-columns: 1fr; max-width: 360px; }
    .practice-grid { grid-template-columns: 1fr; }
    .shorts-rail { grid-template-columns: 1fr 1fr; }
  }
</style>
