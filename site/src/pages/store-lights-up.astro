---
// DRAFT storefront flagship, Direction A "Lights Up" (2026-07-18, personal / gotefigure).
// The After Hours salon, lit up: scroll drives the torch veil off and the warm glow on
// (animations/scroll-choreography.ts). NOT linked from nav, NOT the live store. Preview only
// (Layout bounces here to / unless localStorage 'gf-store-open' is set). Drafts only: every
// price, size, and edition count is an UNVERIFIED placeholder, never a fabricated number.
import Layout from '../layouts/Layout.astro';

// The reissue classics (real hand-drawn ink pieces). Titles are descriptive, not invented
// product names. Prices and edition counts resolve at the drop; placeholders only here.
const drop = [
  { img: '/art/lights-up/rabbit.png',   mat: 'var(--ah-mat-pink)', title: 'the rabbit',  no: 'from the vault' },
  { img: '/art/lights-up/figure2.png',  mat: 'var(--white)',       title: 'figure two',  no: 'from the vault' },
  { img: '/art/lights-up/figure1.png',  mat: 'var(--white)',       title: 'figure one',  no: 'from the vault' },
  { img: '/art/lights-up/mushroom.png', mat: 'var(--white)',       title: 'the mushroom',no: 'from the vault' },
];

// The 2020 archive: sold-out social proof, never reprinted, NOT buyable.
const archive = [
  { img: '/art/lights-up/firetrees.png',  title: 'fire trees' },
  { img: '/art/lights-up/forestwalk.png', title: 'the walk' },
  { img: '/art/lights-up/sfwalk.jpg',     title: 'crossing' },
];
---
<Layout title="The Drop · GoteFigure (draft)" description="Back from 2020. Five years later. Better this time. A salon of hand-drawn work, reissued from the vault." dark={true} gated={false}>
  <div data-lights-up class="lu">

    <!-- fixed salon: lit wall (always), torch veil (scrubs off), warm glow (scrubs in) -->
    <div class="lu-bg" aria-hidden="true"></div>
    <div class="lu-veil" data-veil aria-hidden="true"></div>
    <div class="lu-glow" data-glow aria-hidden="true"></div>

    <!-- ========================= HERO: lights down ========================= -->
    <section class="lu-hero" data-hero>
      <div class="lu-hero-inner">
        <p class="lu-eyebrow lu-eyebrow--lit">Gote Figure</p>
        <h1 class="lu-h1">
          <span>Back from 2020</span>
          <span>Five years later</span>
          <span class="lu-h1-accent">Better this time</span>
        </h1>
        <p class="lu-hero-sub">A salon of hand-drawn work, reissued from the vault.</p>
        <figure class="lu-hero-art">
          <img src="/art/lights-up/hero-poster.jpg" alt="A hand-drawn blue rabbit framed in a paper shrine"
               width="1400" height="788" fetchpriority="high" decoding="async" />
        </figure>
        <p class="lu-scrollhint">the lights are down. scroll to bring them up.</p>
      </div>
    </section>

    <!-- ========================= ON SALE NOW: lit floor ========================= -->
    <section class="lu-floor" data-floor>
      <header class="lu-band-head" data-rv="fade">
        <p class="lu-kicker">The Drop</p>
        <h2 class="lu-band-title">On sale now</h2>
        <p class="lu-band-sub">Classics pulled back from the vault. New numbered editions. Each one, once.</p>
      </header>

      <div class="lu-drop-grid">
        {drop.map((p) => (
          <article class="lu-piece" data-rv="fade">
            <div class="lu-frame">
              <div class="lu-mat" style={`background:${p.mat}`}>
                <img src={p.img} alt={p.title} loading="lazy" decoding="async" />
              </div>
            </div>
            <div class="lu-placard">
              <div class="lu-placard-row">
                <span class="lu-piece-title">{p.title}</span>
                <span class="lu-badge">edition 01 . 1 of N . vaulted</span>
              </div>
              <div class="lu-placard-row">
                <span class="lu-piece-no">{p.no}</span>
                <span class="lu-price">price at drop</span>
              </div>
              <div class="lu-sizes" role="group" aria-label="size">
                <span class="lu-size">S</span><span class="lu-size">M</span><span class="lu-size">L</span><span class="lu-size">XL</span>
              </div>
              <button type="button" class="lu-cta" aria-label={`reserve ${p.title}`}>reserve your size</button>
            </div>
          </article>
        ))}
      </div>

      <p class="lu-order-banner" data-rv="fade">Pre-order. Ships about 2 to 4 weeks after the window closes.</p>
    </section>

    <!-- ========================= TRUST SPINE: lit ========================= -->
    <section class="lu-trust" data-trust>
      <!-- quality -->
      <div class="lu-trust-block" data-rv="fade">
        <p class="lu-kicker">Why it is better this time</p>
        <h3 class="lu-trust-h">Made to last, this time.</h3>
        <ul class="lu-quality">
          <li>Made to survive the wash.</li>
          <li>Premium blanks, not the cheapest.</li>
          <li>Numbered once, never reprinted.</li>
        </ul>
        <p class="lu-fineprint">The exact make is being finalized. No promises we cannot keep.</p>
      </div>

      <!-- maker -->
      <div class="lu-trust-block lu-maker" data-rv="fade">
        <p class="lu-kicker">The maker</p>
        <img class="lu-sig" src="/art/lights-up/signature.png" alt="Gote Figure, hand-signed" loading="lazy" decoding="async" />
        <p class="lu-maker-line">Drawn by hand, the way the first ones were. One human hand, no shortcuts.</p>
      </div>

      <!-- sizing -->
      <div class="lu-trust-block" data-rv="fade">
        <p class="lu-kicker">Sizing</p>
        <h3 class="lu-trust-h">Know it fits before you commit.</h3>
        <table class="lu-size-table">
          <thead><tr><th>Size</th><th>Chest</th><th>Length</th></tr></thead>
          <tbody>
            <tr><td>S</td><td>TBD</td><td>TBD</td></tr>
            <tr><td>M</td><td>TBD</td><td>TBD</td></tr>
            <tr><td>L</td><td>TBD</td><td>TBD</td></tr>
            <tr><td>XL</td><td>TBD</td><td>TBD</td></tr>
          </tbody>
        </table>
        <p class="lu-fineprint">Exact measurements confirmed at the drop. Fits true to size, sized for everyday wear.</p>
      </div>

      <!-- edition / window -->
      <div class="lu-trust-block lu-edition" data-rv="fade">
        <p class="lu-kicker">The edition</p>
        <h3 class="lu-trust-h">The window is the edition.</h3>
        <p class="lu-edition-copy">When the pre-order window closes, the run is set at whatever it sold. Then it is vaulted, and never reprinted.</p>
        <div class="lu-window">
          <span class="lu-window-label">pre-order window</span>
          <span class="lu-window-val">opens at launch</span>
        </div>
      </div>
    </section>

    <!-- ========================= THE ARCHIVE: lights down ========================= -->
    <section class="lu-archive" data-archive>
      <header class="lu-band-head" data-rv="fade">
        <p class="lu-kicker lu-kicker--dim">The Archive</p>
        <h2 class="lu-band-title lu-band-title--dim">The 2020 vault</h2>
        <p class="lu-band-sub lu-band-sub--dim">The first run. It sold out and stays sold out. Kept here as proof, never reprinted.</p>
      </header>

      <div class="lu-archive-grid">
        {archive.map((p) => (
          <article class="lu-vaulted" data-rv="fade">
            <div class="lu-frame lu-frame--dim">
              <div class="lu-mat" style="background:var(--white)">
                <img src={p.img} alt={p.title} loading="lazy" decoding="async" />
              </div>
              <span class="lu-era" aria-hidden="true">2020</span>
            </div>
            <div class="lu-vaulted-cap">
              <span class="lu-piece-title lu-piece-title--dim">{p.title}</span>
              <span class="lu-soldout">gone. for now.</span>
            </div>
          </article>
        ))}
      </div>
      <p class="lu-archive-foot" data-rv="fade">Everything here sold out. It stays as proof.</p>
    </section>

    <footer class="lu-foot">
      <p class="lu-foot-line">Back from 2020. Five years later. Better this time.</p>
      <p class="lu-foot-note">draft direction. nothing here is for sale yet.</p>
    </footer>

  </div>

  <style>
    /* ============ Lights Up storefront (scoped) ============ */
    .lu { position: relative; color: var(--ink); overflow-x: clip; }

    /* fixed salon behind the content */
    .lu-bg, .lu-veil, .lu-glow { position: fixed; inset: 0; pointer-events: none; z-index: 0; }
    .lu-bg {
      background: var(--ah-wall);
      background-image:
        radial-gradient(120% 60% at 50% -8%, rgba(var(--ah-wash), .8), transparent 60%),
        linear-gradient(to bottom, transparent 78%, var(--ah-floor) 92%);
      box-shadow: inset 0 -60px 140px rgba(var(--ink-rgb), .14), inset 0 0 160px rgba(var(--ink-rgb), .06);
    }
    /* torch veil: dark at the edges, a warm hole in the middle (the torch). Opacity scrubbed by JS. */
    .lu-veil {
      z-index: 1; opacity: 1;
      background: radial-gradient(circle 60vh at 50% 34%,
        rgba(var(--ah-beam), .10),
        rgba(var(--ah-night-rgb), 0) 16vh,
        rgba(var(--ah-night-rgb), .58) 40vh,
        rgba(var(--ah-night-rgb), .985) 78vh);
    }
    .lu-glow {
      z-index: 1; opacity: 0;
      background: radial-gradient(120% 52% at 84% -6%, rgba(var(--ah-glow), .3), transparent 60%);
    }

    /* content sits above the fixed salon */
    .lu-hero, .lu-floor, .lu-trust, .lu-archive, .lu-foot { position: relative; z-index: 2; }
    .lu-eyebrow, .lu-kicker { font-family: var(--font-mono); text-transform: uppercase; letter-spacing: .22em; }

    /* ---- hero ---- */
    .lu-hero { min-height: 100svh; display: grid; place-items: center; padding: var(--s-16) var(--s-6) var(--s-24); }
    .lu-hero-inner { width: min(720px, 100%); text-align: center; }
    .lu-eyebrow--lit { font-size: 11px; color: var(--ah-tagline); margin: 0 0 var(--s-6); }
    .lu-h1 { display: grid; gap: .04em; margin: 0; font-family: var(--font-brush); font-weight: 400;
      line-height: .96; font-size: clamp(2.4rem, 1.4rem + 5vw, 4.6rem); color: var(--ah-hero-lit); }
    .lu-h1-accent { color: var(--amber); }
    .lu-hero-sub { margin: var(--s-6) auto 0; font-family: var(--font-scrawl);
      font-size: clamp(1.15rem, 1rem + 1.4vw, 1.7rem); color: var(--ah-sub-dark); transform: rotate(-.5deg); }
    .lu-hero-art { margin: var(--s-12) auto 0; width: min(560px, 100%);
      background: var(--ah-frame); padding: 12px 12px 16px;
      box-shadow: 0 24px 60px rgba(var(--ah-night-rgb), .5), 0 3px 10px rgba(var(--ah-night-rgb), .4);
      transform: rotate(-.8deg); }
    .lu-hero-art img { display: block; width: 100%; height: auto; box-shadow: inset 0 0 0 1px rgba(var(--ink-rgb), .1); }
    .lu-scrollhint { margin: var(--s-12) 0 0; font-family: var(--font-mono); font-size: 11px;
      letter-spacing: .18em; text-transform: uppercase; color: var(--ah-hint); }

    /* ---- shared band header ---- */
    .lu-band-head { width: min(720px, 100%); margin: 0 auto var(--s-12); text-align: center; }
    .lu-kicker { font-size: 11px; color: var(--amber); margin: 0 0 var(--s-3); }
    .lu-band-title { margin: 0; font-family: var(--font-brush); font-weight: 400;
      font-size: clamp(2rem, 1.4rem + 3vw, 3.4rem); line-height: 1; color: var(--ink); }
    .lu-band-sub { margin: var(--s-4) auto 0; max-width: 46ch; font-family: var(--font-hand);
      font-size: 1.05rem; line-height: 1.5; color: var(--body-soft); }

    /* ---- on sale floor ---- */
    .lu-floor { padding: var(--s-24) var(--s-6); }
    .lu-drop-grid { width: min(1040px, 100%); margin: 0 auto; display: grid; gap: var(--s-12);
      grid-template-columns: 1fr; }
    .lu-piece { display: flex; flex-direction: column; gap: var(--s-4); }
    .lu-frame { align-self: center; width: min(360px, 100%); background: var(--ah-frame);
      padding: 14px 14px 18px; box-shadow: 0 18px 40px rgba(var(--ah-night-rgb), .22), 0 2px 6px rgba(var(--ah-night-rgb), .16);
      transform: rotate(-.6deg); }
    .lu-mat { padding: 7%; box-shadow: inset 0 0 0 1px rgba(var(--ink-rgb), .08); }
    .lu-mat img { display: block; width: 100%; height: auto; }
    .lu-placard { width: min(360px, 100%); align-self: center; background: var(--paper);
      padding: var(--s-4) var(--s-6) var(--s-6); box-shadow: 0 8px 20px rgba(var(--ah-night-rgb), .12); }
    .lu-placard-row { display: flex; align-items: baseline; justify-content: space-between; gap: var(--s-3);
      margin-bottom: var(--s-2); }
    .lu-piece-title { font-family: var(--font-scrawl); font-size: 1.6rem; line-height: 1; color: var(--ink); }
    .lu-piece-no { font-family: var(--font-hand); font-size: .95rem; color: var(--muted-dark); }
    .lu-badge { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: .12em; text-transform: uppercase;
      color: var(--teal); border: 1px solid var(--teal); border-radius: 3px; padding: 3px 6px; white-space: nowrap; }
    .lu-price { font-family: var(--font-mono); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted-dark); }
    .lu-sizes { display: flex; gap: var(--s-2); margin: var(--s-3) 0 var(--s-4); }
    .lu-size { font-family: var(--font-mono); font-size: 12px; color: var(--size-idle);
      border: 1px solid var(--muted-3); border-radius: var(--sloppy-quickadd); padding: 5px 10px; }
    .lu-cta { display: block; width: 100%; cursor: pointer; font-family: var(--font-mono); font-size: 12px;
      letter-spacing: .16em; text-transform: uppercase; color: var(--ink); background: var(--amber);
      border: none; border-radius: var(--sloppy-btn); padding: 12px 16px; transition: transform .18s var(--ease-pop), filter .18s ease; }
    .lu-cta:hover { transform: translateY(-1px); filter: brightness(1.04); }
    .lu-cta:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
    .lu-order-banner { width: min(1040px, 100%); margin: var(--s-16) auto 0; text-align: center;
      font-family: var(--font-mono); font-size: 12px; letter-spacing: .1em; color: var(--ink);
      background: rgba(var(--amber-rgb), .16); border: 1px solid var(--amber); border-radius: 4px; padding: 12px 16px; }

    /* ---- trust spine ---- */
    .lu-trust { width: min(1040px, 100%); margin: 0 auto; padding: var(--s-24) var(--s-6);
      display: grid; gap: var(--s-16); grid-template-columns: 1fr; }
    .lu-trust-block { background: var(--card); padding: var(--s-8); box-shadow: 0 10px 28px rgba(var(--ah-night-rgb), .1);
      border-radius: var(--sloppy-tile); }
    .lu-trust-h { margin: var(--s-2) 0 var(--s-4); font-family: var(--font-brush); font-weight: 400;
      font-size: 1.9rem; line-height: 1.05; color: var(--ink); }
    .lu-quality { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--s-3); }
    .lu-quality li { font-family: var(--font-hand); font-size: 1.1rem; color: var(--body-soft); padding-left: var(--s-6); position: relative; }
    .lu-quality li::before { content: ''; position: absolute; left: 0; top: .6em; width: 10px; height: 10px;
      background: var(--teal); border-radius: 50%; }
    .lu-fineprint { margin: var(--s-6) 0 0; font-family: var(--font-mono); font-size: 11px; color: var(--muted); }
    .lu-maker { text-align: center; }
    .lu-sig { height: 64px; width: auto; margin: var(--s-2) auto var(--s-4); display: block; mix-blend-mode: multiply; }
    .lu-maker-line { margin: 0 auto; max-width: 40ch; font-family: var(--font-hand); font-size: 1.15rem; color: var(--body-soft); }
    .lu-size-table { width: 100%; border-collapse: collapse; margin-top: var(--s-2); font-family: var(--font-mono); }
    .lu-size-table th, .lu-size-table td { text-align: left; padding: 10px 8px; border-bottom: 1px solid var(--muted-3); font-size: 13px; }
    .lu-size-table th { color: var(--muted-dark); font-size: 10px; letter-spacing: .14em; text-transform: uppercase; }
    .lu-size-table td { color: var(--ink); }
    .lu-edition-copy { margin: 0 0 var(--s-6); font-family: var(--font-hand); font-size: 1.1rem; color: var(--body-soft); }
    .lu-window { display: flex; align-items: baseline; justify-content: space-between; gap: var(--s-4);
      border-top: 1px dashed var(--muted-3); padding-top: var(--s-4); }
    .lu-window-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted-dark); }
    .lu-window-val { font-family: var(--font-scrawl); font-size: 1.5rem; color: var(--amber); }

    /* ---- archive (dimmed) ---- */
    .lu-archive { padding: var(--s-24) var(--s-6) var(--s-16);
      background: linear-gradient(to bottom, rgba(var(--ah-night-rgb), 0) 0, rgba(var(--ah-night-rgb), .66) 14%, rgba(var(--ah-night-rgb), .78) 100%); }
    .lu-kicker--dim { color: var(--og-pink); }
    .lu-band-title--dim { color: var(--ah-hero-lit); }
    .lu-band-sub--dim { color: var(--dark-body); }
    .lu-archive-grid { width: min(1040px, 100%); margin: 0 auto; display: grid; gap: var(--s-12); grid-template-columns: 1fr; }
    .lu-vaulted { display: flex; flex-direction: column; align-items: center; gap: var(--s-3); }
    .lu-frame--dim { position: relative; width: min(320px, 100%); filter: saturate(.82) brightness(.92); transform: rotate(.5deg); }
    .lu-era { position: absolute; top: -10px; left: -10px; font-family: var(--font-mono); font-size: 10px;
      letter-spacing: .12em; color: var(--paper); background: var(--og-pink); border-radius: 3px; padding: 3px 7px; transform: rotate(-6deg); }
    .lu-vaulted-cap { display: flex; flex-direction: column; align-items: center; gap: 2px; }
    .lu-piece-title--dim { color: var(--dark-tile-muted); }
    .lu-soldout { font-family: var(--font-scrawl); font-size: 1.2rem; color: var(--og-pink); }
    .lu-archive-foot { text-align: center; margin: var(--s-12) auto 0; font-family: var(--font-hand);
      font-size: 1.05rem; color: var(--dark-body); }

    /* ---- footer ---- */
    .lu-foot { position: relative; z-index: 2; text-align: center; padding: var(--s-16) var(--s-6) var(--s-24); background: rgba(var(--ah-night-rgb), .78); }
    .lu-foot-line { margin: 0; font-family: var(--font-brush); font-weight: 400; font-size: 1.6rem; color: var(--ah-hero-lit); }
    .lu-foot-note { margin: var(--s-3) 0 0; font-family: var(--font-mono); font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: var(--muted); }

    /* ---- reveals (paired with animations/reveals.ts; snaps in reduced-motion) ---- */
    [data-rv="fade"] { opacity: 0; transform: translateY(26px); transition: opacity .7s var(--ease-arrive), transform .7s var(--ease-arrive); }

    /* ---- tablet+ layout ---- */
    @media (min-width: 720px) {
      .lu-drop-grid, .lu-archive-grid { grid-template-columns: 1fr 1fr; gap: var(--s-16); }
      .lu-trust { grid-template-columns: 1fr 1fr; }
      .lu-piece, .lu-frame, .lu-placard { align-self: stretch; width: auto; }
      .lu-frame { max-width: 360px; margin: 0 auto; }
      .lu-placard { max-width: 360px; margin: 0 auto; }
    }

    /* ---- reduced motion: lights already up, no reveal offset ---- */
    @media (prefers-reduced-motion: reduce) {
      .lu-veil { opacity: .06 !important; }
      .lu-glow { opacity: 1 !important; }
      [data-rv="fade"] { opacity: 1 !important; transform: none !important; transition: none !important; }
      /* lights resolve UP, so hero text colored for the dark register flips to ink to stay readable.
         the archive and footer keep their own dark panels, so their light text stays readable as-is. */
      .lu-h1 { color: var(--ink); }
      .lu-eyebrow--lit, .lu-hero-sub { color: var(--muted-dark); }
      .lu-scrollhint { display: none; }
    }
  </style>

  <style is:global>
    /* Storefront palette consistency: the shared nav cart-count badge is pink (--pink) as global
       chrome. Scope it off pink on this law-first storefront only (no other page is touched). The
       global recolor is Rotem's call as part of the amber/teal ratification into System_Architecture v1.2. */
    body:has([data-lights-up]) .count { color: var(--muted-dark); }
  </style>
</Layout>
