---
// V2 PDP (research geometry: 7/5 grid, STACKED 1:1 square frames left, sticky boxed buy
// column right — kills the elongated-panel problem). Hand-drawn bones, mono commerce text,
// drawn-checkmark add feedback.
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import RoughFrame from '../../components/RoughFrame.astro';
import { Image } from 'astro:assets';
import { commerce, isMockMode } from '../../lib/commerce';
import { getPhoto } from '../../lib/photos';

export async function getStaticPaths() {
  const products = await commerce.getProducts();
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product: p } = Astro.props;
const all = await commerce.getProducts();
const related = all.filter((x) => x.slug !== p.slug && x.category === p.category).slice(0, 3);

const photoName = p.artSrc.startsWith('photo:') ? p.artSrc.slice(6) : undefined;
const facePhoto = photoName ? getPhoto(photoName) : undefined;
const lifestyle = p.lifestylePhoto && p.lifestylePhoto !== photoName ? getPhoto(p.lifestylePhoto) : undefined;
const pricesDiffer = new Set(p.variants.map((v) => v.price)).size > 1;
const shipNote = p.type === 'apparel'
  ? 'printed to order — usually ships within a week, separately from posters & stickers'
  : 'printed locally in California, packed by the artist — ships in 2–4 days';
---
<Layout title={`${p.name} — GoteFigure`} description={p.description}>
  <article class="pdp">
    <div class="gallery">
      <figure class="panel" style={`view-transition-name: art-${p.slug}`}>
        {facePhoto
          ? <Image src={facePhoto} alt={`${p.name} — product photo`} widths={[700, 1100]} sizes="(max-width: 900px) 94vw, 56vw" loading="eager" class="panel-img panel-img--photo" />
          : <img src={p.artSrc} alt={`${p.name} — the artwork`} loading="eager" class="panel-img" />}
        <RoughFrame seed={p.slug} w={400} h={400} />
      </figure>
      {lifestyle && (
        <figure class="panel">
          <Image src={lifestyle} alt={`${p.name} worn in the wild`} widths={[700, 1100]} sizes="(max-width: 900px) 94vw, 56vw" loading="lazy" class="panel-img panel-img--photo" />
          <RoughFrame seed={`${p.slug}-2`} w={400} h={400} />
          <figcaption class="margin-note">in the wild</figcaption>
        </figure>
      )}
    </div>

    <div class="buy-col">
      <div class="buy-box">
        <RoughFrame seed={`${p.slug}-buy`} w={360} h={420} strokeWidth={1.8} />
        <h1>{p.name}</h1>
        <p class="price mono" data-price>${p.price}</p>
        <p class="desc">{p.description}</p>
        {p.marginNote && <p class="margin-note">{p.marginNote}</p>}

        <form class="buy" data-buy data-slug={p.slug} data-mock={isMockMode ? 'true' : 'false'}>
          {p.variants.length > 1 && (
            <fieldset class="variants">
              <legend class="mono caps">Size</legend>
              <div class="variant-row">
                {p.variants.map((v, i) => (
                  <label class:list={['variant', { 'variant--off': !v.available }]}>
                    <input type="radio" name="variant" value={v.id} data-price={v.price} checked={i === 0} disabled={!v.available} />
                    <span class="mono">{v.label}{pricesDiffer ? ` · $${v.price}` : ''}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          )}
          {p.variants.length === 1 && <input type="hidden" name="variant" value={p.variants[0].id} data-price={p.variants[0].price} />}
          <button type="submit" class="add-btn" data-add-btn data-ink disabled={!p.available}>
            <span class="add-label">{p.available ? 'Add to cart' : 'gone — for now'}</span>
            <svg class="add-check" viewBox="0 0 28 24" aria-hidden="true">
              <path d="M3 13.2 Q9 17 11.5 19.5 Q16 10 25 3.5" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" pathLength="1"/>
            </svg>
          </button>
          <p class="ship-note">{shipNote}</p>
        </form>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <aside class="related" aria-labelledby="related-h">
      <h2 id="related-h">Goes with</h2>
      <div class="related-row">
        {related.map((r) => <ProductCard product={r} />)}
      </div>
    </aside>
  )}
</Layout>

<script>
  import { add } from '../../lib/cart-store';

  function wireBuy() {
    const form = document.querySelector<HTMLFormElement>('[data-buy]');
    if (!form || form.dataset.wired) return;
    form.dataset.wired = 'true';

    form.addEventListener('change', () => {
      const sel = form.querySelector<HTMLInputElement>('input[name="variant"]:checked, input[name="variant"][type="hidden"]');
      if (sel?.dataset.price) document.querySelector('[data-price]')!.textContent = `$${sel.dataset.price}`;
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const sel = form.querySelector<HTMLInputElement>('input[name="variant"]:checked, input[name="variant"][type="hidden"]');
      if (!sel) return;
      const variantId = form.dataset.mock === 'true' ? `${form.dataset.slug}::${sel.value}` : sel.value;
      const btn = form.querySelector<HTMLButtonElement>('[data-add-btn]')!;
      btn.setAttribute('aria-busy', 'true');
      await add(variantId, 1); // state first; animation is feedback, never a gate
      btn.removeAttribute('aria-busy');
      btn.classList.add('added');
      document.dispatchEvent(new CustomEvent('gf:added', { detail: { from: btn } }));
      setTimeout(() => {
        btn.classList.remove('added');
        document.dispatchEvent(new CustomEvent('gf:open-cart'));
      }, 620);
    });
  }
  wireBuy();
  document.addEventListener('astro:page-load', wireBuy);
</script>

<style>
  .pdp {
    display: grid; grid-template-columns: 7fr 5fr; gap: var(--s-8);
    padding: var(--s-8) var(--s-6); max-width: 1180px; margin: 0 auto;
    align-items: start;
  }
  .gallery { display: grid; gap: var(--s-8); }
  .panel { position: relative; aspect-ratio: 1; background: var(--paper); }
  .panel-img { position: absolute; inset: 10px; width: calc(100% - 20px); height: calc(100% - 20px); object-fit: contain; padding: 5%; }
  .panel-img--photo { object-fit: cover; padding: 0; }
  .panel figcaption { position: absolute; bottom: -1.7em; right: var(--s-2); }

  .buy-col { position: sticky; top: 96px; }
  .buy-box { position: relative; padding: var(--s-8) var(--s-6); }
  .buy-box h1 { font-size: var(--text-xl); margin-bottom: var(--s-2); }
  .price { font-size: var(--text-lg); font-weight: 700; margin-bottom: var(--s-4); }
  .desc { font-size: var(--text-sm); max-width: 44ch; margin-bottom: var(--s-3); }

  .buy { margin-top: var(--s-4); }
  .variants { border: none; padding: 0; margin: 0 0 var(--s-4); }
  .variants legend { font-size: 0.72rem; margin-bottom: var(--s-2); }
  .variant-row { display: flex; gap: var(--s-2); flex-wrap: wrap; }
  .variant input { position: absolute; opacity: 0; pointer-events: none; }
  .variant span {
    display: inline-grid; place-items: center; min-width: 44px; min-height: 44px;
    border: 1.5px solid var(--ink); padding: 0 var(--s-3); cursor: pointer;
    font-size: var(--text-sm);
    transition: background var(--dur-quick) var(--ease-arrive);
  }
  .variant input:checked + span { background: var(--ink); color: var(--paper); }
  .variant input:focus-visible + span { outline: 3px solid var(--amber); outline-offset: 2px; box-shadow: 0 0 0 1px var(--ink); }
  .variant--off span { opacity: 0.4; text-decoration: line-through; cursor: not-allowed; }

  .add-btn {
    position: relative; width: 100%; padding: var(--s-4); min-height: 52px;
    font-family: var(--font-mono); font-size: var(--text-base); font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
    background: var(--amber); border: 2px solid var(--ink); border-radius: 2px;
    box-shadow: 4px 4px 0 var(--ink);
    transition: transform var(--dur-quick) var(--ease-arrive), box-shadow var(--dur-quick) var(--ease-arrive);
  }
  .add-btn:not(:disabled):hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--ink); }
  .add-btn:not(:disabled):active { transform: translate(2px, 2px); box-shadow: 1px 1px 0 var(--ink); }
  .add-btn:disabled { background: var(--paper-dim); font-style: italic; text-transform: none; box-shadow: none; font-family: var(--font-hand); }

  .add-check { position: absolute; inset: 0; margin: auto; width: 26px; height: 22px; opacity: 0; }
  .add-check path { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .add-btn.added .add-label { opacity: 0; }
  .add-btn.added .add-check { opacity: 1; }
  .add-btn.added .add-check path { animation: draw-check 300ms var(--ease-arrive) 60ms forwards; }
  @keyframes draw-check { to { stroke-dashoffset: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .add-btn.added .add-check path { animation: none; stroke-dashoffset: 0; }
  }

  .ship-note { font-size: var(--text-sm); color: color-mix(in srgb, var(--ink) 70%, var(--paper)); margin-top: var(--s-3); }

  .related { max-width: 1180px; margin: 0 auto; padding: var(--s-8) var(--s-6) var(--s-16); }
  .related h2 { margin-bottom: var(--s-4); }
  .related-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--s-6); }

  @media (max-width: 900px) {
    .pdp { grid-template-columns: 1fr; gap: var(--s-6); padding-top: var(--s-4); }
    .buy-col { position: static; }
    .related-row { grid-template-columns: 1fr 1fr; }
    .related-row > :global(*:nth-child(3)) { display: none; }
  }
</style>
