---
// V2 home (owner mandate): gotefigure.com IS the shop. No hero, no era split, no
// carousels — announcement, one identity line, THE WALL grouped by category in
// hand-drawn boiling frames, slim maker band, newsletter, done. Calm beats clever.
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import RoughFrame from '../components/RoughFrame.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { commerce, type Category } from '../lib/commerce';
import { CATEGORY_LABELS } from '../lib/commerce/types';
import { roughLinePaths, roughVLine, seedFrom } from '../lib/rough-frame';
import { getVideos, thumb, watchUrl, CHANNEL_URL } from '../lib/youtube';

const products = await commerce.getProducts();
const ORDER: Category[] = ['tees', 'sweats', 'hats', 'prints'];
const groups = ORDER
  .map((cat) => ({ cat, label: CATEGORY_LABELS[cat], items: products.filter((p) => p.category === cat) }))
  .filter((g) => g.items.length > 0);

const videos = (await getVideos()).filter((v) => v.short).slice(0, 3);
const dayMatch = videos.flatMap((v) => v.title.match(/Day (\d+)/) ?? []);
const latestDay = dayMatch.length ? dayMatch[1] : null;

const rulePathsFor = (label: string) => roughLinePaths(seedFrom(label));
---
<Layout
  title="GoteFigure — hand-drawn wearable art, California"
  description="The GoteFigure shop: hand-drawn tees, sweatshirts, posters and stickers. Every piece starts as a pen on paper. Drawn in California."
>
  <!-- The Wink (§7.1 V2): first-visit only, pre-paint gated, skippable -->
  <div id="intro-overlay" aria-hidden="true">
    <div class="wink-stage">
      <img src="/art/rabbit-cameo.webp" alt="" width="800" height="1600" fetchpriority="high" />
      <svg viewBox="0 0 800 1600" class="wink-svg">
        <clipPath id="wink-clip"><ellipse cx="450" cy="947" rx="47" ry="66"/></clipPath>
        <g clip-path="url(#wink-clip)">
          <ellipse id="wink-lid" cx="450" cy="875" rx="47" ry="4" fill="#52767A"/>
        </g>
        <path id="wink-lash" d="M408 1000 Q450 1015 490 997" fill="none" stroke="#111" stroke-width="7" stroke-linecap="round"/>
      </svg>
    </div>
    <p class="intro-skip mono caps">tap to skip</p>
  </div>

  <header class="strip">
    <h1 class="strip-line">every piece starts as a pen on paper<span class="strip-dot" aria-hidden="true">.</span></h1>
    <nav class="strip-nav mono caps" aria-label="Categories">
      {groups.map((g) => <a href={`#${g.cat}`}>{g.label}</a>)}
    </nav>
  </header>

  <div class="wall-wrap">
    <img src="/art/rabbit-stipple.png" alt="" loading="lazy" class="wall-ghost" aria-hidden="true" />

    {groups.map((g, gi) => (
      <section class="cat" id={g.cat} aria-labelledby={`cat-h-${g.cat}`}>
        <svg class="margin-pen" data-scroll-draw viewBox="0 0 24 800" preserveAspectRatio="none" aria-hidden="true">
          {roughVLine(seedFrom(`pen-${g.cat}`)).map((d) => (
            <path d={d} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" vector-effect="non-scaling-stroke" />
          ))}
        </svg>
        <div class="cat-head">
          <h2 id={`cat-h-${g.cat}`}>{g.label}</h2>
          <svg class="cat-rule" viewBox="0 0 600 16" preserveAspectRatio="none" aria-hidden="true">
            {rulePathsFor(g.label).map((paths, i) => (
              <g class={`boil-v boil-v${i}`}>
                {paths.map((d) => <path d={d} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" vector-effect="non-scaling-stroke" />)}
              </g>
            ))}
          </svg>
          <span class="cat-count mono">{g.items.length}</span>
        </div>
        <div class="grid">
          {g.items.map((p, i) => <ProductCard product={p} eager={gi === 0 && i < 3} />)}
        </div>
      </section>
    ))}
  </div>

  <section class="maker" aria-labelledby="maker-h">
    <div class="maker-inner">
      <div class="maker-words">
        <h2 id="maker-h">Drawn every day</h2>
        <p>{latestDay ? `Day ${latestDay} of drawing every single day.` : 'A drawing a day, no skips.'} The art in this shop comes straight out of that practice.</p>
        <a class="squiggle" href={`${CHANNEL_URL}?sub_confirmation=1`} target="_blank" rel="noopener">watch on YouTube →</a>
      </div>
      <div class="maker-thumbs">
        {videos.map((v, i) => (
          <a href={watchUrl(v)} target="_blank" rel="noopener" class="maker-thumb" aria-label={v.title}>
            <img src={thumb(v.id)} alt="" loading="lazy" width="480" height="360"
              onerror={`this.src='https://i.ytimg.com/vi/${v.id}/mqdefault.jpg';this.onerror=null;`} />
            <RoughFrame seed={`yt-${v.id}`} w={160} h={200} strokeWidth={1.6} />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="signup">
    <NewsletterForm context="home" />
  </section>
</Layout>

<style>
  /* ---- The Wink overlay ---- */
  #intro-overlay {
    display: none;
    position: fixed; inset: 0; z-index: var(--z-intro);
    background: var(--paper);
    place-items: center;
  }
  :global(html[data-intro]) #intro-overlay { display: grid; }
  .wink-stage { position: relative; height: min(72svh, 640px); aspect-ratio: 1 / 2; }
  .wink-stage img { height: 100%; width: 100%; object-fit: contain; }
  .wink-svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  #wink-lash { opacity: 0; }
  .intro-skip { position: absolute; bottom: var(--s-6); left: 50%; transform: translateX(-50%); font-size: 0.7rem; opacity: 0.5; }

  /* ---- identity strip ---- */
  .strip {
    display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between;
    gap: var(--s-3); max-width: 1180px; margin: 0 auto;
    padding: var(--s-6) var(--s-6) var(--s-4);
  }
  .strip-line { font-size: var(--text-lg); font-weight: 500; font-variation-settings: 'INFM' 70, 'BNCE' 22; }
  .strip-dot { color: var(--amber); }
  .strip-nav { display: flex; gap: var(--s-6); font-size: 0.75rem; flex-wrap: wrap; }
  .strip-nav a { text-decoration: none; padding: var(--s-2) 0; }
  .strip-nav a:hover { color: var(--teal-text); }

  /* ---- the wall ---- */
  .wall-wrap { position: relative; max-width: 1180px; margin: 0 auto; padding: 0 var(--s-6); overflow-x: clip; }
  .wall-ghost {
    position: absolute; right: 4px; top: 220px; width: 360px; max-width: 40vw;
    opacity: 0.05; pointer-events: none; z-index: 0;
  }
  .cat { position: relative; z-index: 1; padding: var(--s-8) 0 var(--s-4); scroll-margin-top: 90px; }
  .margin-pen {
    position: absolute; left: -52px; top: var(--s-6); bottom: var(--s-2);
    width: 24px; height: calc(100% - var(--s-8)); color: color-mix(in srgb, var(--ink) 55%, var(--paper));
    display: none;
  }
  @media (min-width: 1290px) { .margin-pen { display: block; } }
  .cat-head { display: flex; align-items: center; gap: var(--s-4); margin-bottom: var(--s-6); }
  .cat-head h2 { font-size: var(--text-xl); flex: none; }
  .cat-rule { flex: 1; height: 14px; color: var(--ink); min-width: 40px; }
  .cat-rule .boil-v { display: none; }
  .cat-rule .boil-v0 { display: block; }
  :global(html[data-boil='1']) .cat-rule .boil-v0, :global(html[data-boil='2']) .cat-rule .boil-v0 { display: none; }
  :global(html[data-boil='1']) .cat-rule .boil-v1 { display: block; }
  :global(html[data-boil='2']) .cat-rule .boil-v2 { display: block; }
  .cat-count { font-size: 0.72rem; border: 1.5px solid var(--ink); padding: 1px 9px; }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-8) var(--s-6);
  }

  /* ---- maker band (slim, one row) ---- */
  .maker { border-top: 2px solid var(--ink); margin-top: var(--s-12); background: color-mix(in srgb, var(--paper-dim) 55%, var(--paper)); }
  .maker-inner {
    max-width: 1180px; margin: 0 auto; padding: var(--s-8) var(--s-6);
    display: flex; gap: var(--s-12); align-items: center; justify-content: space-between; flex-wrap: wrap;
  }
  .maker-words { max-width: 40ch; }
  .maker-words h2 { font-size: var(--text-lg); margin-bottom: var(--s-2); }
  .maker-words p { font-size: var(--text-sm); margin-bottom: var(--s-2); }
  .maker-thumbs { display: flex; gap: var(--s-4); }
  .maker-thumb { position: relative; width: 132px; }
  .maker-thumb img { aspect-ratio: 4 / 5; object-fit: cover; padding: 6px; }

  .signup { max-width: 1180px; margin: 0 auto; padding: var(--s-12) var(--s-6) var(--s-8); }

  @media (max-width: 860px) {
    .grid { grid-template-columns: repeat(2, 1fr); gap: var(--s-6) var(--s-4); }
    .maker-thumb:nth-child(3) { display: none; }
  }
  @media (max-width: 480px) {
    .strip { padding-inline: var(--s-4); }
    .wall-wrap { padding-inline: var(--s-4); }
    .maker-inner { gap: var(--s-6); }
    .maker-words { min-width: 0; }
    .maker-thumbs { max-width: 100%; }
    .maker-thumb { width: min(126px, 26vw); min-width: 0; flex: none; }
  }
</style>
