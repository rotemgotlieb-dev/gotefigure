---
// SITE ROOT (/) — After Hours "dark salon", the pre-launch takeover shown at gotefigure.com
// while the shop is closed. The real store home is preserved at /store (not deleted) and is gated
// behind the author code entered via the hidden corner button (logic in src/animations/after-hours.ts).
// 1:1 with the approved Claude Design mock. Desktop = a fixed 1512x946 stage scaled to the viewport;
// all stage geometry lives under @media (min-width:1024px). Mobile reflow owned by the parallel branch.
import AfterHoursLayout from '../layouts/AfterHoursLayout.astro';
import { Image } from 'astro:assets';
import committee from '../assets/after-hours/work-01-committee.png';
import twins from '../assets/after-hours/work-02-twins.png';
import hare from '../assets/after-hours/work-03-hare.png';
import brainWeather from '../assets/after-hours/work-04-brain-weather.png';
import regular from '../assets/after-hours/work-05-regular.png';
import overthinking from '../assets/after-hours/work-06-overthinking.png';
import fourBirds from '../assets/after-hours/work-07-four-birds.png';
import logotype from '../assets/after-hours/logotype.png';
import signature from '../assets/after-hours/signature.png';
import wallTag from '../assets/after-hours/wall-tag.png';

// Each framed work: image + geometry (desktop stage coords) + caption. Values verbatim from the mock.
const frames = [
  { img: committee, w: 893, h: 424, alt: 'Nine ink heads in a row', title: 'the committee', no: 'NO 001 · INK · NOT FOR SALE (YET)',
    l: '14.6%', t: '10.6%', rot: '-1.5deg', fw: '348px', fpad: '5.3% 5.3% 7.3%', inner: 'var(--ah-mat-inner)', ipad: '0',
    shadow: '0 16px 38px rgba(12,9,6,.28), 0 2px 6px rgba(12,9,6,.2)', capPad: '5px 10px 4px', capMt: '9px', tSize: '20px', capRot: '.8deg' },
  { img: twins, w: 1000, h: 954, alt: 'Pink mirrored figures', title: 'the twins', no: 'NO 007 · SEEING DOUBLE',
    l: '31%', t: '66.7%', rot: '1.8deg', fw: '150px', fpad: '8% 8% 11.3%', inner: 'var(--ah-mat-inner)', ipad: '8%',
    shadow: '0 16px 38px rgba(12,9,6,.28)', capPad: '5px 10px 4px', capMt: '9px', tSize: '20px', capRot: '-.6deg' },
  { img: hare, w: 500, h: 1000, alt: 'The hare, wide-eyed', title: 'the hare', no: 'NO 002 · DO NOT FEED',
    l: '14.2%', t: '62.5%', rot: '1.4deg', fw: '151px', fpad: '12.4% 12.4% 17.1%', inner: 'var(--ah-pink-mat)', ipad: '0',
    shadow: '0 16px 38px rgba(12,9,6,.28)', capPad: '5px 10px 4px', capMt: '9px', tSize: '20px', capRot: '-1deg' },
  { img: brainWeather, w: 1000, h: 699, alt: 'Pink liquid maze blob', title: 'brain weather', no: 'NO 003 · WET PAINT',
    l: '39.2%', t: '17.4%', rot: '1.6deg', fw: '237px', fpad: '5.8% 5.8% 7.7%', inner: 'var(--ah-mat-inner)', ipad: '0',
    shadow: '0 16px 38px rgba(12,9,6,.28)', capPad: '5px 10px 4px', capMt: '9px', tSize: '20px', capRot: '-.7deg' },
  { img: regular, w: 1000, h: 800, alt: 'Teal antenna creature', title: 'the regular', no: 'NO 004 · HE WAITS TOO',
    l: '78.6%', t: '19.1%', rot: '-2deg', fw: '151px', fpad: '9.2% 9.2% 13.1%', inner: 'var(--ah-mat-inner)', ipad: '7.7%',
    shadow: '0 14px 32px rgba(12,9,6,.28)', capPad: '4px 9px 3px', capMt: '8px', tSize: '18px', capRot: '1deg' },
  { img: overthinking, w: 674, h: 651, alt: 'Tangled colour maze', title: 'overthinking', no: 'NO 005 · MARKER',
    l: '54.2%', t: '67.6%', rot: '-1.6deg', fw: '210px', fpad: '7.6% 7.6% 10.6%', inner: 'var(--ah-mat-inner)', ipad: '0',
    shadow: '0 16px 38px rgba(12,9,6,.28)', capPad: '4px 9px 3px', capMt: '8px', tSize: '18px', capRot: '.9deg' },
  { img: fourBirds, w: 833, h: 704, alt: 'Four mirrored birds', title: 'four birds, one bird', no: 'NO 006 · MIRRORED',
    l: '60%', t: '17.4%', rot: '1.2deg', fw: '215px', fpad: '7% 7% 9.5%', inner: 'var(--ah-mat-inner)', ipad: '0',
    shadow: '0 16px 38px rgba(12,9,6,.28)', capPad: '4px 9px 3px', capMt: '8px', tSize: '18px', capRot: '-.8deg' },
];
---
<AfterHoursLayout
  title="GoteFigure — after hours"
  description="The shop opens soon. Grab a torch and wander the dark salon, then leave your email to hear when the next drop lands."
>
  <div id="ah-root" class="ah" data-screen-label="After Hours — the dark salon">

    <!-- grain -->
    <div class="ah-grain" aria-hidden="true"></div>

    <!-- COPY (DOM-first for mobile reading; desktop places it on top of the darkness) -->
    <div class="ah-front" data-stage-front>
      <header id="ah-header" class="ah-header">
        <div class="ah-brand">
          <Image class="ah-wm" data-wm src={logotype} width={300} alt="Gote Figure" format="webp" />
          <span class="ah-tagline" data-tagline>· after hours</span>
        </div>
      </header>

      <div id="ah-headline" class="ah-copy">
        <div class="ah-h-stack">
          <h1 class="ah-h ah-h--dark" data-h-dark>the lights aren't on yet.</h1>
          <h1 class="ah-h ah-h--lit" data-h-lit>there, that's better.</h1>
        </div>
        <div class="ah-sub-stack">
          <p class="ah-sub ah-sub--dark" data-s-dark>the shop opens soon. meanwhile, you brought a torch. have a wander.</p>
          <p class="ah-sub ah-sub--lit" data-s-lit>welcome to the salon. everything hangs, nothing's for sale (yet).</p>
        </div>
        <div class="ah-hint" data-hint>somewhere, a cord is hanging · pull it</div>
      </div>
    </div>

    <!-- THE ROOM (fully lit underneath; darkness sits on top on desktop) -->
    <div class="ah-room" data-stage-back data-room>
      <div class="ah-walllight ah-desk" aria-hidden="true"></div>
      <div class="ah-vignette ah-desk" aria-hidden="true"></div>
      <div class="ah-floor ah-desk" aria-hidden="true"></div>
      <div class="ah-rail ah-desk" aria-hidden="true"></div>
      <Image class="ah-walltag ah-desk" src={wallTag} width={410} alt="" aria-hidden="true" format="webp" />

      <!-- FRAMES -->
      <div id="ah-gallery" class="ah-gallery" data-art-band>
        {frames.map((f) => (
          <div class="ah-frame" style={`--l:${f.l};--t:${f.t};--rot:${f.rot};--fw:${f.fw}`}>
            <div class="ah-frame-mat" style={`padding:${f.fpad};box-shadow:${f.shadow}`}>
              <div class="ah-frame-inner" style={`background:${f.inner};${f.ipad !== '0' ? `padding:${f.ipad};` : ''}`}>
                <Image src={f.img} width={f.w} height={f.h} alt={f.alt} format="webp" />
              </div>
            </div>
            <div class="ah-cap-wrap" style={`margin-top:${f.capMt}`}>
              <div class="ah-cap" style={`padding:${f.capPad};transform:rotate(${f.capRot})`}>
                <div class="ah-cap-title" style={`font-size:${f.tSize}`}>{f.title}</div>
                <div class="ah-cap-no">{f.no}</div>
              </div>
            </div>
          </div>
        ))}

        <!-- eyes in the dark (fade as the beam nears) -->
        <div class="ah-eyes ah-desk" data-eyes aria-hidden="true">
          <span class="ah-eye"></span>
          <span class="ah-eye ah-eye--2"></span>
        </div>
      </div>

      <!-- THE CORD -->
      <button class="ah-cord ah-desk" data-cord type="button" aria-label="pull the light cord" title="pull">
        <span class="ah-cord-inner" data-cord-inner>
          <span class="ah-cord-string"></span>
          <span class="ah-cord-knob"></span>
        </span>
      </button>

      <!-- EMAIL CARD (the linchpin) -->
      <div id="ah-notify" class="ah-email" data-email-card>
        <span class="ah-tape ah-tape--1" aria-hidden="true"></span>
        <span class="ah-tape ah-tape--2" aria-hidden="true"></span>
        <div class="ah-email-h">tell me when the shop opens&nbsp;→</div>
        <div class="ah-email-wrap" data-email-wrap>
          <form class="ah-email-form" data-email-form>
            <input class="ah-email-input" data-email-input type="email" required placeholder="you@email" aria-label="your email" />
            <button class="ah-email-btn" type="submit">notify</button>
          </form>
        </div>
        <div class="ah-email-done" data-email-done>noted. ♥ you're on the list.</div>
        <a class="ah-email-link" href="/notebooks">meanwhile: the sketchbooks →</a>
      </div>

      <!-- signature -->
      <div id="ah-signature" class="ah-signature">
        <Image class="ah-sig-img" src={signature} width={200} alt="Gote — signature" format="webp" />
        <span class="ah-sig-label">works on paper</span>
      </div>
    </div>

    <!-- DARKNESS (the beam is a hole in this layer) + warm ceiling glow -->
    <div class="ah-dark ah-desk" data-dark aria-hidden="true"></div>
    <div class="ah-glow ah-desk" data-glow aria-hidden="true"></div>

    <!-- author gate: a near-invisible corner dot; the code unlocks the closed store at /store -->
    <div class="ah-gate" data-gate>
      <button class="ah-gate-dot" data-gate-toggle type="button" aria-label="author access"></button>
      <form class="ah-gate-form" data-gate-form hidden>
        <input class="ah-gate-input" data-gate-input type="password" autocomplete="off" spellcheck="false" aria-label="access code" placeholder="code" />
        <button class="ah-gate-go" type="submit" aria-label="enter">→</button>
      </form>
    </div>

  </div>
</AfterHoursLayout>

<style>
  /* ================================================================
     SHARED — fonts, colors, keyframes, the frame/caption/email look
     (breakpoint-independent visual treatment; sizes/positions split below)
     ================================================================ */
  .ah { position: fixed; inset: 0; overflow: hidden; }

  .ah-grain {
    position: fixed; inset: 0; z-index: 10500; pointer-events: none;
    mix-blend-mode: multiply; opacity: .22;
    background-image: url('/art/after-hours/grain.png'); background-repeat: repeat;
  }

  /* author gate — tiny, near-invisible corner dot; opens a code field that unlocks /store */
  .ah-gate { position: fixed; right: 10px; bottom: 10px; z-index: 10600; display: flex; align-items: center; gap: 6px; }
  .ah-gate-dot { width: 12px; height: 12px; padding: 0; border: none; border-radius: 50%; background: var(--ah-gray); opacity: .1; cursor: pointer; transition: opacity .3s ease; }
  .ah-gate-dot:hover, .ah-gate[data-open] .ah-gate-dot { opacity: .55; }
  .ah-gate-form[hidden] { display: none; }
  .ah-gate-form { display: flex; align-items: center; gap: 4px; background: var(--ah-card); padding: 5px 6px; box-shadow: 0 6px 18px rgba(12,9,6,.35); }
  .ah-gate-input { width: 110px; border: none; border-bottom: 1.5px solid var(--ah-ink); background: transparent; padding: 4px 2px; font-family: var(--font-typewriter); font-size: 13px; color: var(--ah-ink); outline: none; }
  .ah-gate-go { border: none; background: var(--ah-ink); color: var(--ah-card); cursor: pointer; font-family: var(--font-typewriter); font-size: 12px; padding: 4px 9px; border-radius: 3px; }
  .ah-gate-go:hover { background: var(--ah-pink); }

  /* frame + caption look */
  .ah-frame-mat { background: var(--ah-mat); }
  .ah-frame-inner { box-shadow: inset 0 0 0 1px rgba(22,19,15,.08); }
  .ah-frame-inner :global(img) { width: 100%; height: auto; }
  .ah-cap-wrap { display: flex; justify-content: center; }
  .ah-cap { background: var(--ah-mat); box-shadow: 0 3px 8px rgba(12,9,6,.25); text-align: left; }
  .ah-cap-title { font-family: var(--font-marker); line-height: 1; color: var(--ah-ink); white-space: nowrap; }
  .ah-cap-no { font-family: var(--font-typewriter); font-size: 10px; letter-spacing: .18em; color: var(--ah-gray); margin-top: 3px; white-space: nowrap; }

  /* copy */
  .ah-brand { display: flex; align-items: flex-end; gap: 14px; }
  .ah-wm { height: 40px; width: auto; filter: invert(1) brightness(1.6); transition: filter .9s ease; }
  .ah-tagline { font-family: var(--font-marker); color: var(--ah-tag-dark); transform: rotate(-2deg) translateY(-4px); display: inline-block; transition: color .9s ease; }
  .ah-h { margin: 0; font-family: var(--font-brush); font-weight: 400; line-height: .92; transition: opacity .9s ease; }
  .ah-h--dark { color: var(--ah-h-dark); }
  .ah-h--lit { color: var(--ah-h-lit); }
  .ah-sub { margin: 0; font-family: var(--font-marker); transform: rotate(-.6deg); transition: opacity .9s ease; }
  .ah-sub--dark { color: var(--ah-sub-dark); }
  .ah-sub--lit { color: var(--ah-sub-lit); }
  .ah-hint { font-family: var(--font-typewriter); letter-spacing: .26em; text-transform: uppercase; color: var(--ah-hint-dark); transition: color .9s ease; }

  /* email card */
  .ah-email { background: var(--ah-card); }
  .ah-email-h { font-family: var(--font-marker); color: var(--ah-ink); -webkit-text-stroke: .6px var(--ah-ink); transform: rotate(-.8deg); }
  .ah-email-form { display: flex; gap: 6px; }
  .ah-email-input { flex: 1; min-width: 0; border: none; border-bottom: 1.5px solid var(--ah-ink); background: transparent; padding: 6px 2px; color: var(--ah-ink); outline: none; font-family: var(--font-typewriter); }
  .ah-email-input::placeholder { color: var(--ah-placeholder); }
  .ah-email-btn { border: none; background: var(--ah-ink); color: var(--ah-card); cursor: pointer; font-family: var(--font-typewriter); letter-spacing: .16em; text-transform: uppercase; border-radius: 3px; transition: background .25s; }
  .ah-email-btn:hover { background: var(--ah-pink); }
  .ah-email-done { font-family: var(--font-marker); color: var(--ah-ink); }
  .ah-email-link { display: inline-block; font-family: var(--font-typewriter); font-size: 10px; letter-spacing: .18em; text-transform: uppercase; color: var(--ah-gray); text-decoration: none; border-bottom: 1px solid rgba(138,132,120,.5); padding-bottom: 2px; transition: color .25s, border-color .25s; }
  .ah-email-link:hover { color: var(--ah-pink); border-color: var(--ah-pink); }

  .ah-sig-img { mix-blend-mode: multiply; }
  .ah-sig-label { font-family: var(--font-typewriter); font-size: 10px; letter-spacing: .26em; text-transform: uppercase; color: var(--ah-gray); }

  /* keyframes */
  @keyframes gfah-flickon { 0%{opacity:1} 52%{opacity:1} 56%{opacity:.12} 63%{opacity:.82} 70%{opacity:.04} 79%{opacity:.38} 100%{opacity:0} }
  @keyframes gfah-sway { 0%,100%{transform:rotate(-2.2deg)} 50%{transform:rotate(2.2deg)} }
  @keyframes gfah-blink { 0%,91%,100%{transform:scaleY(1)} 94%,97%{transform:scaleY(.08)} }
  @keyframes gfah-pop { 0%{transform:scale(.85) rotate(2deg);opacity:0} 60%{transform:scale(1.04) rotate(2deg)} 100%{transform:scale(1) rotate(2deg);opacity:1} }
  @keyframes gfah-wob { 0%,100%{transform:translateX(0)} 22%{transform:translateX(-5px)} 46%{transform:translateX(5px)} 70%{transform:translateX(-3px)} }
  @keyframes gfah-hintpulse { 0%,100%{opacity:.85} 50%{opacity:.35} }

  /* ================================================================
     MOBILE BASE  (< 1024px)  — placeholder stack; the parallel branch
     owns/refines this. Coherent + not broken: lit room, content stacked.
     ================================================================ */
  .ah-desk { display: none; }                 /* torch/room-lighting/cord/eyes are desktop-only */
  .ah { position: relative; min-height: 100dvh; background: var(--ah-wall); overflow: visible; }
  .ah-front { padding: 24px 20px 0; }
  .ah-header { display: flex; }
  .ah-wm { filter: none; }                     /* wall is light on mobile */
  .ah-tagline { color: var(--ah-tag-lit); }
  .ah-h-stack .ah-h--dark, .ah-sub-stack .ah-sub--dark { display: none; }   /* no torch => show the lit copy */
  .ah-h { font-size: clamp(2.75rem, 12vw, 4rem); }
  .ah-sub { font-size: var(--text-lg); margin-top: var(--s-2); }
  .ah-hint { display: none; }
  .ah-room { position: relative; background: var(--ah-wall); padding: var(--s-8) var(--s-4) var(--s-16); }
  .ah-gallery { display: flex; flex-direction: column; gap: var(--s-12); align-items: center; }
  .ah-frame { width: min(78vw, 340px); }
  .ah-email { position: static; width: min(90vw, 340px); margin: var(--s-12) auto 0; padding: 14px 16px 16px; box-shadow: 0 14px 34px rgba(12,9,6,.3); transform: rotate(2deg); }
  .ah-email-h { font-size: 32px; }
  .ah-email-input { font-size: 16px; }          /* >=16px: no iOS zoom-on-focus */
  .ah-email-btn { font-size: 11px; padding: 10px 14px; }  /* >=24px tap target */
  .ah-email-done { display: none; margin-top: 8px; font-size: 21px; }
  .ah-email-link { margin-top: 10px; }
  .ah-signature { display: flex; align-items: center; gap: 10px; justify-content: center; opacity: .85; margin-top: var(--s-8); }
  .ah-sig-img { height: 24px; width: auto; }

  /* ================================================================
     DESKTOP STAGE  (>= 1024px)  — the fixed 1512x946 scaled canvas.
     Interior px/%/deg = canvas geometry (like an SVG viewBox), see
     .claude/token-exceptions.txt. This branch (luxembourg) owns this block.
     ================================================================ */
  @media (min-width: 1024px) {
    .ah-desk { display: block; }
    .ah { position: fixed; inset: 0; min-height: 0; overflow: hidden; background: var(--ah-black); }

    /* the two scaled stages (JS sets translate(-50%,-50%) scale(...)) */
    .ah-room, .ah-front { position: absolute; left: 50%; top: 50%; width: 1512px; height: 946px; transform: translate(-50%,-50%); transform-origin: center; }
    .ah-room { background: var(--ah-wall); overflow: hidden; z-index: 1; padding: 0; }
    .ah-front { z-index: 40; pointer-events: none; padding: 0; }

    /* room lighting */
    .ah-walllight { position: absolute; inset: 0; pointer-events: none; background-image: radial-gradient(115% 85% at 50% -6%, rgba(255,248,233,.75), transparent 58%); }
    .ah-vignette { position: absolute; inset: 0; pointer-events: none; box-shadow: inset 0 -46px 130px rgba(22,19,15,.16), inset 0 0 150px rgba(22,19,15,.08); }
    .ah-floor { position: absolute; left: 0; right: 0; bottom: 0; height: 10.5%; background: var(--ah-floor); box-shadow: inset 0 10px 18px rgba(22,19,15,.18); }
    .ah-rail { position: absolute; left: 0; right: 0; bottom: 10.5%; height: 5px; background: var(--ah-rail); box-shadow: 0 2px 4px rgba(22,19,15,.22); }
    .ah-walltag { position: absolute; left: 50%; top: 49%; width: 397px; height: auto; transform: translate(-50%,-50%) rotate(-4deg); opacity: .07; mix-blend-mode: multiply; pointer-events: none; }

    /* frames band + frames */
    .ah-gallery { position: absolute; left: 0; right: 0; top: 255px; bottom: 99px; z-index: 2; display: block; }
    .ah-frame { position: absolute; left: var(--l); top: var(--t); width: var(--fw); transform: translate(-50%,-50%) rotate(var(--rot)); z-index: 2; }
    .ah-cap-wrap { margin-top: 9px; }

    /* eyes */
    .ah-eyes { position: absolute; left: 7%; top: 50%; display: flex; gap: 10px; z-index: 3; opacity: 1; transition: opacity .4s ease; }
    .ah-eye { width: 9px; height: 13px; background: var(--ah-eyes); border-radius: 50%; box-shadow: 0 0 12px rgba(255,233,168,.9); animation: gfah-blink 4.6s ease infinite; }
    .ah-eye--2 { animation-delay: .07s; }

    /* cord */
    .ah-cord { position: absolute; left: 86%; top: 0; transform: translateX(-50%); height: 36%; width: 72px; background: none; border: none; padding: 0; cursor: pointer; z-index: 6; outline: none; }
    .ah-cord-inner { position: absolute; left: 50%; top: 0; transform: translateX(-50%); transform-origin: top center; height: 100%; display: block; animation: gfah-sway 4.5s ease-in-out infinite; }
    .ah-cord-string { position: absolute; left: 50%; top: 0; transform: translateX(-50%); width: 3px; height: calc(100% - 42px); background: var(--ah-cord-string); display: block; }
    .ah-cord-knob { position: absolute; left: 50%; bottom: 2px; transform: translateX(-50%); width: 23px; height: 42px; background: linear-gradient(160deg, var(--ah-cord-knob-1), var(--ah-cord-knob-2)); border-radius: 46% 54% 50% 50% / 40% 40% 60% 60%; box-shadow: 0 3px 8px rgba(12,9,6,.4), inset 0 1px 2px rgba(255,255,255,.35); display: block; }

    /* email card */
    .ah-email { position: absolute; right: 6%; bottom: 20.5%; width: 300px; margin: 0; padding: 14px 16px 16px; box-shadow: 0 14px 34px rgba(12,9,6,.3); transform: rotate(2deg); z-index: 4; }
    .ah-tape { position: absolute; }
    .ah-tape--1 { left: -12px; top: -10px; width: 62px; height: 22px; background: rgba(233,226,205,.92); box-shadow: 0 1px 3px rgba(22,19,15,.18); transform: rotate(-22deg); }
    .ah-tape--2 { right: -10px; bottom: -8px; width: 56px; height: 20px; background: rgba(218,114,133,.4); box-shadow: 0 1px 3px rgba(22,19,15,.14); transform: rotate(-18deg); }
    .ah-email-h { font-size: 36px; }
    .ah-email-wrap { margin-top: 8px; }
    .ah-email-input { font-size: 13px; }
    .ah-email-btn { font-size: 10.5px; padding: 0 11px; }
    .ah-email-done { display: none; margin-top: 8px; font-size: 21px; }
    .ah-email-link { margin-top: 10px; }

    /* signature */
    .ah-signature { position: absolute; left: 24px; bottom: 2.6%; display: flex; align-items: center; gap: 10px; opacity: .85; z-index: 4; margin: 0; }
    .ah-sig-img { height: 24px; width: auto; }

    /* copy (stage-front) */
    .ah-header { position: absolute; left: 0; right: 0; top: 0; z-index: 40; display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; padding: 22px 28px 0; pointer-events: none; }
    .ah-wm { filter: invert(1) brightness(1.6); }
    .ah-tagline { color: var(--ah-tag-dark); font-size: 23px; }
    .ah-copy { position: absolute; left: 50%; top: 95px; transform: translateX(-50%); z-index: 40; width: 820px; text-align: center; pointer-events: none; }
    .ah-h-stack, .ah-sub-stack { display: grid; }
    .ah-h-stack .ah-h--dark, .ah-sub-stack .ah-sub--dark { display: block; }
    .ah-h-stack > .ah-h { grid-area: 1 / 1; font-size: 82px; }
    .ah-h--lit { opacity: 0; }
    .ah-sub-stack { margin-top: .2em; }
    .ah-sub-stack > .ah-sub { grid-area: 1 / 1; margin: 0; font-size: 31px; }
    .ah-sub--lit { opacity: 0; }
