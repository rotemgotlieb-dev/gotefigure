---
// After Hours — the dark salon (mobile). Pre-order demand-capture page. 1:1 reproduction of the
// approved Claude Design artifact (GoteFigure After Hours Phone.dc.html). Single-screen, no-scroll:
// a torch-lit dark room, a wall of framed drawings, a pull-cord light switch, an email capture.
// Interaction lives in animations/after-hours.ts (torch/eyes/toggle/email). Chromeless shell.
// cqw units and clamp() values are verbatim from the mock; every colour resolves to a token.
import Immersive from '../layouts/Immersive.astro';
---
<Immersive
  title="After Hours — GoteFigure"
  description="The lights aren't on yet. GoteFigure is coming back — a salon of hand-drawn work. Leave your email and we'll tell you when the shop opens."
>
  <!-- film grain (matches V3 --z-grain layer, mock opacity .22) -->
  <div class="ah-grain" aria-hidden="true"></div>

  <div class="ah-screen" data-screen-label="After Hours — the dark salon (phone)">
    <div class="ah-stage" data-room-stage>

      <!-- the salon wall -->
      <div style="position:absolute;inset:0;background:var(--ah-wall)">
        <div style="position:absolute;inset:0;background-image:radial-gradient(130% 60% at 50% -6%,rgba(var(--ah-wash),.75),transparent 58%);pointer-events:none"></div>
        <div style="position:absolute;inset:0;box-shadow:inset 0 -40px 110px rgba(var(--ink-rgb),.16),inset 0 0 120px rgba(var(--ink-rgb),.08);pointer-events:none"></div>
        <div style="position:absolute;left:0;right:0;bottom:0;height:7.5%;background:var(--ah-floor);box-shadow:inset 0 10px 18px rgba(var(--ink-rgb),.18)"></div>
        <div style="position:absolute;left:0;right:0;bottom:7.5%;height:4px;background:var(--ah-skirt);box-shadow:0 2px 4px rgba(var(--ink-rgb),.22)"></div>

        <!-- ghosted background drawing -->
        <img src="/art/after-hours/ghost.png" alt="" aria-hidden="true" decoding="async"
          style="position:absolute;left:50%;top:52%;width:92cqw;height:auto;transform:translate(-50%,-50%) rotate(-4deg);opacity:.07;mix-blend-mode:multiply;pointer-events:none" />

        <!-- NO 001 · the committee -->
        <div style="position:absolute;left:36%;top:40%;transform:translate(-50%,-50%) rotate(-1.5deg);width:58cqw;z-index:6">
          <div style="background:var(--ah-frame);padding:2cqw 2cqw 2.6cqw;box-shadow:0 14px 32px rgba(var(--ah-night-rgb),.28),0 2px 6px rgba(var(--ah-night-rgb),.2)">
            <div style="background:var(--white);box-shadow:inset 0 0 0 1px rgba(var(--ink-rgb),.08)">
              <img src="/art/after-hours/committee.png" alt="Nine ink heads in a row" decoding="async" style="width:100%;height:auto" />
            </div>
          </div>
          <div style="display:flex">
            <div style="background:var(--ah-frame);padding:5px 10px 4px;box-shadow:0 3px 8px rgba(var(--ah-night-rgb),.25);transform:rotate(.8deg);text-align:left">
              <div style="font-family:var(--font-scrawl);font-size:clamp(13px,4.6cqw,19px);line-height:1;color:var(--ink);white-space:nowrap">the committee</div>
              <div style="font-family:var(--font-mono);font-size:clamp(7px,2.3cqw,9px);letter-spacing:.16em;color:var(--muted);white-space:nowrap">NO 001 · INK · NOT FOR SALE (YET)</div>
            </div>
          </div>
        </div>

        <!-- NO 002 · the hare -->
        <div style="position:absolute;left:80%;top:43.5%;transform:translate(-50%,-50%) rotate(1.4deg);width:21cqw;z-index:5">
          <div style="background:var(--ah-frame);padding:1.8cqw 1.8cqw 2.4cqw;box-shadow:0 14px 30px rgba(var(--ah-night-rgb),.28)">
            <div style="background:var(--ah-mat-pink);box-shadow:inset 0 0 0 1px rgba(var(--ink-rgb),.08)">
              <img src="/art/after-hours/hare.png" alt="The hare, wide-eyed" decoding="async" style="width:100%;height:auto" />
            </div>
          </div>
          <div style="display:flex">
            <div style="background:var(--ah-frame);padding:4px 9px 3px;box-shadow:0 3px 8px rgba(var(--ah-night-rgb),.25);transform:rotate(-1deg);text-align:left">
              <div style="font-family:var(--font-scrawl);font-size:clamp(13px,4.6cqw,19px);line-height:1;color:var(--ink);white-space:nowrap">the hare</div>
              <div style="font-family:var(--font-mono);font-size:clamp(7px,2.3cqw,9px);letter-spacing:.16em;color:var(--muted);white-space:nowrap">NO 002 · DO NOT FEED</div>
            </div>
          </div>
        </div>

        <!-- NO 003 · brain weather -->
        <div style="position:absolute;left:38%;top:63.5%;transform:translate(-50%,-50%) rotate(1.6deg);width:36cqw;z-index:4">
          <div style="background:var(--ah-frame);padding:2cqw 2cqw 2.7cqw;box-shadow:0 14px 32px rgba(var(--ah-night-rgb),.28)">
            <div style="background:var(--white);box-shadow:inset 0 0 0 1px rgba(var(--ink-rgb),.08)">
              <img src="/art/after-hours/brain-weather.png" alt="Pink liquid maze blob" decoding="async" style="width:100%;height:auto" />
            </div>
          </div>
          <div style="display:flex">
            <div style="background:var(--ah-frame);padding:5px 10px 4px;box-shadow:0 3px 8px rgba(var(--ah-night-rgb),.25);transform:rotate(-.7deg);text-align:left">
              <div style="font-family:var(--font-scrawl);font-size:clamp(13px,4.6cqw,19px);line-height:1;color:var(--ink);white-space:nowrap">brain weather</div>
              <div style="font-family:var(--font-mono);font-size:clamp(7px,2.3cqw,9px);letter-spacing:.16em;color:var(--muted);white-space:nowrap">NO 003 · WET PAINT</div>
            </div>
          </div>
        </div>

        <!-- NO 004 · the regular -->
        <div style="position:absolute;left:78%;top:67.5%;transform:translate(-50%,-50%) rotate(-2deg);width:21cqw;z-index:3">
          <div style="background:var(--ah-frame);padding:1.8cqw 1.8cqw 2.4cqw;box-shadow:0 12px 28px rgba(var(--ah-night-rgb),.3)">
            <div style="background:var(--white);box-shadow:inset 0 0 0 1px rgba(var(--ink-rgb),.08)">
              <img src="/art/after-hours/regular.png" alt="Teal antenna creature" decoding="async" style="width:100%;height:auto" />
            </div>
          </div>
          <div style="display:flex">
            <div style="background:var(--ah-frame);padding:4px 9px 3px;box-shadow:0 3px 8px rgba(var(--ah-night-rgb),.25);transform:rotate(1deg);text-align:left">
              <div style="font-family:var(--font-scrawl);font-size:clamp(13px,4.6cqw,19px);line-height:1;color:var(--ink);white-space:nowrap">the regular</div>
              <div style="font-family:var(--font-mono);font-size:clamp(7px,2.3cqw,9px);letter-spacing:.16em;color:var(--muted);white-space:nowrap">NO 004 · HE WAITS TOO</div>
            </div>
          </div>
        </div>

        <!-- glowing eyes in the dark -->
        <div data-eyes style="position:absolute;left:8%;top:63%;display:flex;gap:2.3cqw;z-index:3;opacity:1;transition:opacity .4s ease">
          <span style="width:1.8cqw;height:2.6cqw;background:var(--ah-lamp);border-radius:50%;box-shadow:0 0 12px rgba(var(--ah-lamp-rgb),.9);animation:gfahm-blink 4.6s ease infinite"></span>
          <span style="width:1.8cqw;height:2.6cqw;background:var(--ah-lamp);border-radius:50%;box-shadow:0 0 12px rgba(var(--ah-lamp-rgb),.9);animation:gfahm-blink 4.6s ease infinite .07s"></span>
        </div>

        <!-- the pull cord (light switch) -->
        <button data-cord type="button" aria-label="pull the light cord"
          style="position:absolute;left:92%;top:0;transform:translateX(-50%);height:17%;width:56px;background:none;border:none;padding:0;z-index:6">
          <span data-cord-inner style="position:absolute;left:50%;top:0;transform:translateX(-50%);transform-origin:top center;height:100%;display:block">
            <span style="position:absolute;left:50%;top:0;transform:translateX(-50%);width:2px;height:calc(100% - 6.2cqw);background:var(--ah-cord-string);display:block"></span>
            <span style="position:absolute;left:50%;bottom:.5cqw;transform:translateX(-50%);width:3.4cqw;height:6.2cqw;background:linear-gradient(160deg,var(--ah-cord-a),var(--ah-cord-b));border-radius:46% 54% 50% 50%/40% 40% 60% 60%;box-shadow:0 3px 8px rgba(var(--ah-night-rgb),.4),inset 0 1px 2px rgba(var(--white-rgb),.35);display:block"></span>
          </span>
        </button>

        <!-- email capture card -->
        <div data-email-card style="position:absolute;left:4cqw;right:4cqw;bottom:calc(11cqw + env(safe-area-inset-bottom));background:var(--paper);padding:3.6cqw 4cqw;box-shadow:0 14px 34px rgba(var(--ah-night-rgb),.3);transform:rotate(1.2deg);z-index:4">
          <span aria-hidden="true" style="position:absolute;left:-10px;top:-9px;width:14cqw;height:5cqw;background:rgba(var(--ah-tape-rgb),.92);box-shadow:0 1px 3px rgba(var(--ink-rgb),.18);transform:rotate(-22deg)"></span>
          <span aria-hidden="true" style="position:absolute;right:-8px;bottom:-7px;width:13cqw;height:4.6cqw;background:rgba(var(--pink-rgb),.4);box-shadow:0 1px 3px rgba(var(--ink-rgb),.14);transform:rotate(-18deg)"></span>
          <div style="font-family:var(--font-scrawl);font-size:clamp(17px,6cqw,24px);color:var(--ink);transform:rotate(-.8deg)">tell me when the shop opens →</div>
          <div data-email-wrap style="margin-top:2cqw">
            <form data-email-form style="display:flex;gap:2cqw">
              <input data-email-input type="email" required placeholder="you@email" aria-label="your email"
                style="flex:1;min-width:0;border:none;border-bottom:1.5px solid var(--ink);background:transparent;padding:2.5cqw 2px;font-size:clamp(12px,3.6cqw,14px);color:var(--ink);outline:none" />
              <button type="submit" style="border:none;background:var(--ink);color:var(--paper);font-family:var(--font-mono);font-size:clamp(9px,2.9cqw,11px);letter-spacing:.14em;text-transform:uppercase;padding:0 3.6cqw;border-radius:3px">notify</button>
            </form>
          </div>
          <div data-email-done style="display:none;margin-top:2cqw;font-family:var(--font-scrawl);font-size:clamp(17px,6cqw,24px);color:var(--ink)">noted. ♥ you're on the list.</div>
          <a href="/info" style="display:inline-block;margin-top:2cqw;font-family:var(--font-mono);font-size:clamp(8px,2.6cqw,10px);letter-spacing:.16em;text-transform:uppercase;color:var(--muted);padding:2px 0 3px">meanwhile: the sketchbooks →</a>
        </div>

        <!-- works-on-paper signature -->
        <div style="position:absolute;left:4cqw;bottom:calc(2.4cqw + env(safe-area-inset-bottom));display:flex;align-items:center;gap:2.3cqw;opacity:.85;z-index:4">
          <img src="/art/after-hours/signature.png" alt="Gote — signature" decoding="async" style="height:5cqw;width:auto;mix-blend-mode:multiply" />
          <span style="font-family:var(--font-mono);font-size:clamp(7px,2.3cqw,9px);letter-spacing:.22em;text-transform:uppercase;color:var(--muted)">works on paper</span>
        </div>
      </div>

      <!-- the darkness (torch beam painted here by JS) -->
      <div data-dark style="position:absolute;inset:0;z-index:20;pointer-events:none;opacity:1;background:radial-gradient(circle 280px at 50% 45%, rgba(var(--ah-beam),.09), rgba(var(--ah-night-rgb),0) 56px, rgba(var(--ah-night-rgb),.55) 135px, rgba(var(--ah-night-rgb),.987) 260px)"></div>

      <!-- warm room glow when the lights are on -->
      <div data-glow style="position:absolute;inset:0;z-index:21;pointer-events:none;opacity:0;transition:opacity 1.1s ease;background:radial-gradient(120% 46% at 86% -4%,rgba(var(--ah-glow),.32),transparent 62%)"></div>

      <!-- header -->
      <header style="position:absolute;left:0;right:0;top:0;z-index:40;display:flex;align-items:flex-start;justify-content:space-between;gap:3.6cqw;padding:4.1cqw 4.1cqw 0;pointer-events:none">
        <div style="display:flex;align-items:baseline;gap:2.6cqw">
          <img data-wm src="/art/after-hours/wordmark.png" alt="Gote Figure" decoding="async" style="height:7.7cqw;min-height:22px;width:auto;filter:invert(1) brightness(1.6);transition:filter .9s ease" />
          <span data-tagline style="font-family:var(--font-scrawl);font-size:clamp(13px,4.8cqw,19px);color:var(--ah-tagline);transform:rotate(-2deg) translateY(-3px);display:inline-block;transition:color .9s ease;white-space:nowrap">— after hours</span>
        </div>
      </header>

      <!-- hero -->
      <div style="position:absolute;left:50%;top:12%;transform:translateX(-50%);z-index:40;width:92cqw;text-align:center;pointer-events:none">
        <div style="display:grid;font-size:clamp(26px,11cqw,42px)">
          <h1 data-h-dark style="grid-area:1/1;margin:0;font-family:var(--font-brush);font-weight:400;font-size:1em;line-height:.95;color:var(--ah-hero-lit);opacity:1;transition:opacity .9s ease">the lights aren't on yet.</h1>
          <h1 data-h-lit style="grid-area:1/1;margin:0;font-family:var(--font-brush);font-weight:400;font-size:1em;line-height:.95;color:var(--ink);opacity:0;transition:opacity .9s ease">there, that's better.</h1>
        </div>
        <div style="display:grid;font-size:clamp(14px,5cqw,20px);line-height:1.25;margin-top:2cqw">
          <p data-s-dark style="grid-area:1/1;margin:0;font-family:var(--font-scrawl);font-size:1em;color:var(--ah-sub-dark);transform:rotate(-.6deg);opacity:1;transition:opacity .9s ease">the shop opens soon. you brought a torch — have a wander.</p>
          <p data-s-lit style="grid-area:1/1;margin:0;font-family:var(--font-scrawl);font-size:1em;color:var(--ah-sub-lit);transform:rotate(-.6deg);opacity:0;transition:opacity .9s ease">welcome to the salon. everything hangs, nothing's for sale (yet).</p>
        </div>
        <div data-hint style="margin-top:2cqw;font-family:var(--font-mono);font-size:clamp(9px,2.8cqw,11px);letter-spacing:.26em;text-transform:uppercase;color:var(--ah-hint);animation:gfahm-hintpulse 3.4s ease infinite;transition:color .9s ease">drag your thumb · a cord hangs somewhere</div>
      </div>

    </div>
  </div>

  <!-- author access gate: faint bottom-right dot → code → preview the (not-yet-open) store on production.
       Code is client-side (a soft gate, not real security). Set GATE_CODE in animations/after-hours.ts. -->
  <div class="ah-gate" data-gate>
    <button type="button" data-gate-btn class="ah-gate-dot" aria-label="author access"></button>
    <form data-gate-form class="ah-gate-form" hidden>
      <input data-gate-input type="password" inputmode="text" autocomplete="off" aria-label="access code" placeholder="code" />
      <button type="submit" class="ah-gate-go" aria-label="unlock">→</button>
    </form>
  </div>
</Immersive>

<style is:global>
  /* After Hours motion keyframes (verbatim from the mock; global so inline animation: refs resolve) */
  @keyframes gfahm-flickon { 0%{opacity:1} 52%{opacity:1} 56%{opacity:.12} 63%{opacity:.82} 70%{opacity:.04} 79%{opacity:.38} 100%{opacity:0} }
  @keyframes gfahm-sway { 0%,100%{transform:rotate(-2.2deg)} 50%{transform:rotate(2.2deg)} }
  @keyframes gfahm-blink { 0%,91%,100%{transform:scaleY(1)} 94%,97%{transform:scaleY(.08)} }
  @keyframes gfahm-pop { 0%{transform:scale(.85) rotate(2deg);opacity:0} 60%{transform:scale(1.04) rotate(2deg)} 100%{transform:scale(1) rotate(2deg);opacity:1} }
  @keyframes gfahm-wob { 0%,100%{transform:translateX(0)} 22%{transform:translateX(-5px)} 46%{transform:translateX(5px)} 70%{transform:translateX(-3px)} }
  @keyframes gfahm-hintpulse { 0%,100%{opacity:.85} 50%{opacity:.35} }

  .ah-grain {
    position: fixed; inset: 0; z-index: var(--z-grain);
    pointer-events: none; mix-blend-mode: multiply; opacity: .22;
    background-image: url("/art/after-hours/grain.png"); background-repeat: repeat; /* mock's noise tile, natural size (1:1) */
  }
  .ah-screen { position: fixed; inset: 0; display: flex; justify-content: center; background: var(--ah-night); }
  .ah-stage {
    position: relative; height: 100%; width: min(100vw, 52dvh);
    overflow: hidden; touch-action: none; container-type: size;
  }

  /* author access gate — deliberately faint; 44px hit area, 9px visible dot */
  .ah-gate { position: fixed; right: 0; bottom: 0; z-index: 11000; display: flex; align-items: center; gap: 6px; padding-right: env(safe-area-inset-right); padding-bottom: env(safe-area-inset-bottom); }
  .ah-gate-dot { width: 44px; height: 44px; padding: 0; border: none; background: transparent; cursor: pointer; position: relative; }
  .ah-gate-dot::after { content: ''; position: absolute; right: 9px; bottom: 9px; width: 9px; height: 9px; border-radius: 50%; background: var(--ah-hint); opacity: .12; transition: opacity .3s ease; }
  .ah-gate-dot:hover::after, .ah-gate-dot:focus-visible::after { opacity: .55; }
  .ah-gate-form { display: flex; align-items: center; gap: 4px; margin: 0 8px 8px 0; background: rgba(var(--ah-night-rgb), .78); padding: 4px 6px; border-radius: 4px; }
  .ah-gate-form[hidden] { display: none; }
  .ah-gate-form input { width: 100px; font-family: var(--font-mono); font-size: 16px; color: var(--ah-wall); background: transparent; border: none; border-bottom: 1px solid var(--ah-hint); outline: none; padding: 2px; }
  .ah-gate-go { border: none; background: transparent; color: var(--ah-wall); font-family: var(--font-mono); font-size: 15px; padding: 2px 4px; cursor: pointer; }
</style>
