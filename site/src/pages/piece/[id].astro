---
// PIECE — the placard PDP (design lines 330-409). art | worn | detail views; worn is a labeled
// placeholder until the owner drops the real photo (never invent stand-ins — HANDOFF rule).
// GATED (review 2026-07-10 #1): renders on the Worker behind the same signed cookie as /store,
// so the pre-launch catalog is not prerendered + publicly fetchable. Was getStaticPaths/static.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import InkButton from '../../components/InkButton.astro';
import {
  pieces, drop, isLive, isBetween, dropLow, money, SIZES,
} from '../../lib/drop';
import { GATE_COOKIE, gateOpen } from '../../lib/gate';

if (!(await gateOpen(Astro.cookies.get(GATE_COOKIE)?.value))) return Astro.redirect('/', 302);

const p = pieces.find((x) => x.id === Astro.params.id);
if (!p) return Astro.redirect('/store', 302);

const scarcity = isLive
  ? (p.original ? '1 of 1 — one buyer, one wall' : `${drop.left} of ${drop.editionSize} left — never reprinted`)
  : 'vaulted — this piece will never be reprinted';
const cta = p.original ? `Claim the original — ${money(p.price)}` : `Add to bag — ${money(p.price)}`;
---
<Layout title={`${p.name} — GoteFigure`} description={p.desc}>
  <div class="piece" data-piece-page data-piece-id={p.id} data-sized={p.sized ? '1' : undefined}>
    <a href="/#shop" class="back mono">← the drop</a>

    <div class="cols">
      <div>
        <div class="stage">
          <div class="view art" data-view="art" role="img" aria-label={p.name} style={`width:${p.artW};background-image:url('${p.art}')`}></div>
          <div class="view worn" data-view="worn" hidden>
            <span class="mono">ON-BODY / IN-ROOM PHOTO<br />— the real shot lands here —</span>
          </div>
          <div class="view detail" data-view="detail" hidden role="img" aria-label="detail view" style={`background-image:url('${p.art}')`}></div>
        </div>
        <div class="thumbs" data-thumbs>
          <button type="button" data-thumb="art" aria-pressed="true">art</button>
          <button type="button" data-thumb="worn" aria-pressed="false">worn</button>
          <button type="button" data-thumb="detail" aria-pressed="false">detail</button>
        </div>
      </div>

      <div>
        <div class="kind">{p.kind}</div>
        <h1 class="brush">{p.name}</h1>
        <div class="price">{money(p.price)}</div>
        <p class="desc">{p.desc}</p>

        {p.sized && (
          <>
            <div class="sizes" data-sizes>
              {SIZES.map((s) => <button type="button" data-size={s}>{s}</button>)}
            </div>
            <div class="size-error" data-size-error hidden>Pick a size first.</div>
          </>
        )}

        <div class="scarcity mono" style={`color:${dropLow || p.original ? 'var(--pink)' : 'var(--hand-muted)'}`}>
          <span class="pulse-dot"></span>{scarcity}
        </div>

        {isLive && <div class="cta"><InkButton label={cta} add="pdp" wide size="lg" /></div>}
        {isBetween && <div class="vaulted-cta mono">Vaulted — gone for good</div>}

        <div class="trust mono" data-ink-obstacle>free US shipping · 30-day size swaps · secure checkout</div>

        <div class="metabox">
          <div class="meta mono">{p.meta}</div>
          {p.sized && (
            <details>
              <summary class="mono">measurements ▾</summary>
              <div class="mono measurements">XS 18" · S 19.5" · M 21" · L 23" · XL 25" — chest, laid flat.<br />Cold wash inside-out, hang dry. The print ages with you.</div>
            </details>
          )}
        </div>

        <div class="notewrap">
          <p class="note brush">{p.note}</p>
          <img src="/art/v3/signature.png" alt="Rotem" class="mini-sig" width="1554" height="1146" />
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .brush { font-family: var(--font-brush); font-weight: 400; }
  .piece { max-width: 1120px; margin: 0 auto; padding: 34px 28px 100px; animation: gf-fadein .4s ease; }
  /* hand-drawn skin: everything in main goes handwritten (design ground truth) */
  .back, .scarcity, .trust, .meta, summary, .measurements, .vaulted-cta { font-family: var(--font-scrawl); }
  .back { display: inline-block; font-size: 16px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--hand-muted); text-decoration: none; padding: 6px 0; margin-bottom: 26px; transition: color .25s; }
  .back:hover { color: var(--ink); }
  .cols { display: grid; grid-template-columns: minmax(320px, 1.04fr) minmax(300px, .96fr); gap: clamp(34px, 5vw, 72px); align-items: start; }

  .stage {
    position: relative; background: var(--card); border: 1px solid rgba(22, 19, 15, .12);
    border-radius: 4px;
    aspect-ratio: 4 / 4.6; display: flex; align-items: center; justify-content: center;
    overflow: hidden; padding: 34px;
  }
  .view.art { height: 100%; background-position: center; background-size: contain; background-repeat: no-repeat; animation: gf-fadein .45s ease; }
  .view.worn {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    background: repeating-linear-gradient(-45deg, rgba(22,19,15,.04) 0 14px, transparent 14px 28px);
  }
  .view.worn span { font-size: 15px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--hand-muted); text-align: center; line-height: 2; }
  .view.detail { position: absolute; inset: 0; background-position: center; background-size: 190% auto; background-repeat: no-repeat; animation: gf-fadein .45s ease; }
  .thumbs { display: flex; gap: 10px; margin-top: 14px; }
  .thumbs button {
    border: 1px solid rgba(22, 19, 15, .25); background: transparent; border-radius: var(--sloppy-btn);
    padding: 8px 16px; font-size: 17px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase;
    transition: all .25s; color: var(--hand-muted);
  }
  .thumbs button[aria-pressed="true"] { border-color: var(--ink); background: var(--ink); color: var(--paper); }

  .kind { font-size: 15px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--hand-muted); margin-bottom: 14px; }
  h1 { font-size: clamp(44px, 4.6vw, 62px); line-height: 1; margin: 0 0 10px; }
  .price { font-size: 24px; font-weight: 700; margin-bottom: 22px; }
  .desc { font-family: var(--font-hand); font-size: 18px; line-height: 1.5; color: var(--body-soft); margin: 0 0 26px; max-width: 44ch; }

  .sizes { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .sizes button {
    position: relative; border: none; background: none;
    font-family: var(--font-mono); font-size: 17px; font-weight: 700;
    padding: 10px 14px; letter-spacing: .08em; color: var(--size-idle);
    border-bottom: 5px solid transparent; transition: color .2s, border-color .2s;
  }
  .sizes button[aria-pressed="true"] { border-bottom-color: var(--pink); color: var(--ink); }
  .size-error { font-size: 16px; font-weight: 700; color: var(--pink); margin-bottom: 8px; }

  .scarcity { display: flex; align-items: center; gap: 9px; font-size: 16px; font-weight: 700; letter-spacing: .09em; margin: 14px 0 18px; }
  .pulse-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--pink); flex-shrink: 0; animation: gf-pulse 1.6s ease-in-out infinite; }
  .cta { position: relative; z-index: 5; margin-bottom: 14px; }
  .vaulted-cta {
    width: 100%; border: 2px solid rgba(22, 19, 15, .25); border-radius: var(--sloppy-pill);
    padding: 18px 34px; text-align: center; font-size: 20px; font-weight: 700; color: var(--muted-2); margin-bottom: 14px;
  }
  .trust { font-size: 15px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--hand-muted); margin-bottom: 30px; width: fit-content; }

  .metabox { border-top: 1px solid rgba(22, 19, 15, .14); padding: 18px 2px 0; display: flex; flex-direction: column; gap: 8px; margin-bottom: 26px; }
  .meta { font-size: 16px; line-height: 1.8; color: var(--muted-dark); }
  details { font-size: 16px; color: var(--muted-dark); }
  summary { cursor: pointer; font-size: 15px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--hand-muted); padding: 6px 0; }
  .measurements { font-size: 16px; line-height: 2; padding-top: 8px; }

  .notewrap { display: flex; align-items: flex-end; justify-content: space-between; gap: 14px; }
  .note { font-size: 24px; line-height: 1.4; color: var(--body-soft); margin: 0; max-width: 24ch; transform: rotate(-1deg); }
  .mini-sig { height: 34px; width: auto; opacity: .85; flex-shrink: 0; }

  @media (max-width: 820px) {
    .cols { grid-template-columns: 1fr; }
  }
</style>
