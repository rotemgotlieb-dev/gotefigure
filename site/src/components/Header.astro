---
// v3 header — wordmark, The Drop / The Vault, Bag pill (design lines 54-69; hand-drawn skin:
// brush-stroke bottom edge instead of a border, -0.25deg lean).
---
<header class="gf-header">
  <div class="bar">
    <a href="/" class="logo" title="GoteFigure">
      <img src="/art/v3/wordmark.png" alt="Gote Figure" width="1046" height="492" />
    </a>
    <nav aria-label="Store">
      <a href="/#shop" class="navlink">The Drop</a>
      <a href="/vault/" class="navlink">The Vault</a>
    </nav>
    <button class="bag" data-open-satchel type="button">
      <span>Bag</span>
      <span class="count" data-cart-count aria-label="items in bag">0</span>
    </button>
  </div>
</header>

<style>
  .gf-header {
    position: sticky; top: 0; z-index: var(--z-header);
    background-color: rgba(247, 245, 240, .86);
    backdrop-filter: blur(10px);
    rotate: -0.25deg;
    background-image: url("data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 1400 10%27 preserveAspectRatio=%27none%27%3E%3Cpath d=%27M0 5.8 C 120 3.2 300 4.0 520 4.6 C 760 5.2 960 3.4 1140 4.4 C 1260 5.0 1350 4.4 1400 5.2 L 1400 6.0 C 1310 7.4 1180 6.2 1000 7.0 C 800 7.9 600 6.4 420 7.2 C 260 7.9 120 6.8 0 7.4 Z%27 fill=%27%2316130F%27 fill-opacity=%27.9%27/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: left bottom;
    background-size: 100% 9px;
  }
  .bar {
    max-width: 1320px; margin: 0 auto; padding: 0 28px; height: 76px;
    display: flex; align-items: center; gap: 44px;
  }
  .logo { display: flex; align-items: center; padding: 6px 0; margin-right: auto; }
  .logo img { height: 52px; width: auto; }
  nav { display: flex; gap: 38px; align-items: center; font-size: 19px; letter-spacing: .04em; text-transform: uppercase; }
  .navlink {
    color: var(--ink); text-decoration: none; padding: 6px 0;
    background-image: linear-gradient(var(--ink), var(--ink));
    background-repeat: no-repeat; background-position: 0 100%; background-size: 0% 1.5px;
    transition: background-size .3s;
  }
  .navlink:hover, .navlink:focus-visible { background-size: 100% 1.5px; }
  .bag {
    border: 2px solid var(--ink); background: transparent; border-radius: 999px;
    padding: 11px 24px; display: flex; align-items: center; gap: 10px;
    font-size: 19px; letter-spacing: .04em; text-transform: uppercase; color: var(--ink);
    transition: background .25s, color .25s;
  }
  .bag:hover, .bag:focus-visible { background: var(--ink); color: var(--paper); }
  .count { font-family: var(--font-mono); font-weight: 700; color: var(--pink); }

  @media (max-width: 640px) {
    .bar { gap: 18px; padding: 0 16px; }
    nav { gap: 16px; font-size: 17px; }
    .logo img { height: 40px; }
    .bag { padding: 9px 16px; font-size: 17px; }
  }
</style>
