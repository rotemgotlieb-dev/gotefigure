---
// Drop-grid tile (design lines 170-257): art, kind chip, brush name + pink underline that
// draws on hover + two hanging drips, price, quick-add with rising ink pool, vaulted overlay.
import type { Piece } from '../lib/drop';
import { isBetween, dropLeftShort, money } from '../lib/drop';

interface Props { piece: Piece; delay?: number; }
const { piece: p, delay = 0 } = Astro.props;
const dark = !!p.original;
---
<article
  data-tile
  data-cat={p.category}
  data-rv="fade"
  data-rv-d={delay || undefined}
  class:list={['tile', { dark }]}
>
  {p.hero && !isBetween && <span class="corner mono">{dropLeftShort}</span>}
  {dark && <span class="corner mono">1 of 1</span>}

  <a class="tile-link" href={`/piece/${p.id}/`} aria-label={`${p.name}, ${p.kindShort}, ${money(p.price)}`}></a>

  <div class="artbox" class:list={[{ 'paper-well': dark }]}>
    <img data-tart src={p.art} alt="" style={`max-width:${p.tileArtMax}`} loading="lazy" />
  </div>
  <div class="kind">{p.kindShort}</div>
  <div class="namewrap">
    <h3>{p.name}</h3>
    <svg viewBox="0 0 100 7" preserveAspectRatio="none" aria-hidden="true" class="u-svg">
      <path data-u d={p.underline} pathLength="1" fill="none" stroke="#DA7285" stroke-width="2.4" stroke-linecap="round" stroke-dasharray="1" stroke-dashoffset="1"></path>
    </svg>
    <svg viewBox="0 0 100 12" preserveAspectRatio="none" aria-hidden="true" class="dr-svg">
      <path data-dr d="M9.8 0.4 C10.2 2.8 10.1 5.4 9.8 7.6 C9.6 9.1 8.9 9.2 8.7 7.7 C8.5 5.2 8.6 2.6 8.9 0.4 Z" fill="#DA7285" opacity=".8" style="transform:scaleY(0);transform-origin:9px 0px;transition:transform .8s cubic-bezier(.25,.6,.3,1) .35s"></path>
      <path data-dr d="M91 0.4 C91.3 2 91.2 3.6 91 5 C90.8 6.2 90.2 6.3 90 5.1 C89.9 3.4 90 1.8 90.2 0.4 Z" fill="#DA7285" opacity=".8" style="transform:scaleY(0);transform-origin:90px 0px;transition:transform .7s cubic-bezier(.25,.6,.3,1) .6s"></path>
    </svg>
  </div>
  <div class="price">{money(p.price)}</div>
  <button data-quickadd={p.id} type="button" class="qa">
    <span data-qa-lbl>+ Quick add</span>
    <span data-qa-pool aria-hidden="true"></span>
  </button>
  {dark && <div class="paper-note mono">the actual paper →</div>}

  {isBetween && (
    <div class="vaulted" class:list={[{ dark }]}>
      <span>{dark ? 'sold · vaulted' : 'vaulted'}</span>
    </div>
  )}
</article>

<style>
  /* base tile + hand-drawn L2 skin: sloppy radius, 2px ink border, offset shadow,
     alternating lean (nth-of-type set by parent grid), double-outline ring */
  .tile {
    opacity: 0; transform: translateY(18px);
    transition: opacity .7s ease, transform .7s var(--ease-tile), box-shadow .5s;
    position: relative;
    background: var(--card);
    border: 2px solid var(--ink);
    border-radius: var(--sloppy-tile);
    box-shadow: 4px 5px 0 rgba(22, 19, 15, .85);
    padding: 34px 26px 26px;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    overflow: visible;
  }
  .tile::after {
    content: ''; position: absolute; inset: -6px;
    border: 1.6px solid rgba(22, 19, 15, .75);
    border-radius: var(--sloppy-tile-ring);
    rotate: .6deg; pointer-events: none;
  }
  .tile:hover { box-shadow: 0 26px 48px -32px rgba(22, 19, 15, .4), 4px 5px 0 rgba(22, 19, 15, .85); }
  .tile.dark { background: var(--ink); border-color: var(--ink); }
  .tile.dark:hover { box-shadow: 0 26px 48px -30px rgba(22, 19, 15, .55), 4px 5px 0 rgba(22, 19, 15, .85); }

  .tile-link { position: absolute; inset: 0; z-index: 1; border-radius: inherit; }
  .corner { position: absolute; top: 14px; right: 14px; font-family: var(--font-scrawl); font-size: 15px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--pink); z-index: 2; }

  .artbox { height: 230px; width: 100%; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; }
  .artbox.paper-well { background: var(--card); border-radius: 2px; }
  .artbox img { max-height: 96%; object-fit: contain; transition: transform .5s var(--ease-tile); width: auto; }

  .kind { font-size: 16px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--hand-muted); margin-bottom: 8px; }
  .tile.dark .kind { color: var(--dark-tile-muted); }
  .namewrap { display: inline-block; position: relative; }
  h3 { font-family: var(--font-brush); font-weight: 400; font-size: 44px; line-height: 1; margin: 0; -webkit-text-stroke: 1px currentColor; }
  .tile.dark h3 { color: var(--paper); }
  .u-svg { width: 100%; height: 7px; display: block; margin-top: 4px; }
  .u-svg [data-u] { transition: stroke-dashoffset .5s ease; }
  .dr-svg { position: absolute; top: 86%; left: 0; width: 100%; height: 12px; overflow: visible; pointer-events: none; }
  .price { font-size: 26px; font-weight: 700; margin-top: 10px; }
  .tile.dark .price { color: var(--paper); }

  .qa {
    margin-top: 16px; position: relative; overflow: hidden; z-index: 2;
    border: none; border-radius: var(--sloppy-quickadd);
    background: var(--ink); color: var(--paper);
    padding: 14px 28px;
    font-family: var(--font-hand); font-size: 23px; font-weight: 700; letter-spacing: .06em;
    box-shadow: 3px 3px 0 rgba(22, 19, 15, .35);
    transition: background .25s, color .25s;
  }
  .tile.dark .qa { background: var(--paper); color: var(--ink); }
  .qa [data-qa-lbl] { position: relative; z-index: 1; pointer-events: none; }
  .qa [data-qa-pool] {
    position: absolute; left: -6px; right: -6px; bottom: -4px; height: 0;
    background: var(--pink); opacity: .95;
    border-radius: 55% 45% 0 0 / 100% 85% 0 0;
    pointer-events: none;
    transition: height 1.8s cubic-bezier(.22, .55, .3, 1);
  }
  .paper-note { margin-top: 16px; font-size: 15px; letter-spacing: .09em; text-transform: uppercase; color: var(--hand-muted); }
  .tile.dark .paper-note { color: var(--dark-tile-muted); }

  .vaulted {
    position: absolute; inset: 0; z-index: 3;
    background: rgba(247, 245, 240, .72);
    display: flex; align-items: center; justify-content: center;
    border-radius: inherit;
  }
  .vaulted span {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .3em; text-transform: uppercase;
    color: var(--ink); border: 1.5px solid var(--ink); border-radius: 999px; padding: 8px 18px;
    transform: rotate(-8deg); background: var(--paper);
  }
  .vaulted.dark { background: rgba(22, 19, 15, .78); }
  .vaulted.dark span { color: var(--paper); border-color: var(--paper); background: transparent; }
</style>
