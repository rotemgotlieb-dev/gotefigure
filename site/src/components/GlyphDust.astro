---
// Stitch-glyph dust (§3.3): sparse decorative field behind a section.
// Deterministic pseudo-random placement (seeded) so builds are stable.
interface Props { seed?: number; count?: number }
const { seed = 7, count = 14 } = Astro.props;
const GLYPHS = ['#g-plus', '#g-equal', '#g-hash', '#g-x', '#g-dot'];
let s = seed;
const rand = () => { s = (s * 16807) % 2147483647; return s / 2147483647; };
const dots = Array.from({ length: count }, (_, i) => ({
  href: GLYPHS[i % GLYPHS.length],
  x: 2 + rand() * 96,
  y: 4 + rand() * 92,
  size: 9 + rand() * 9,
  rot: Math.round(rand() * 60 - 30),
  speed: 0.18 + rand() * 0.3, // parallax factor consumed by scroll-life.ts
}));
---
<div class="dust" aria-hidden="true" data-dust>
  {dots.map((d) => (
    <svg class="glyph" data-speed={d.speed.toFixed(2)}
      style={`left:${d.x.toFixed(1)}%; top:${d.y.toFixed(1)}%; width:${d.size.toFixed(0)}px; transform: rotate(${d.rot}deg);`}
      viewBox="0 0 24 24">
      <use href={`/art/glyphs.svg${d.href}`} />
    </svg>
  ))}
</div>

<style>
  .dust { position: absolute; inset: 0; z-index: var(--z-dust); pointer-events: none; overflow: hidden; }
  .glyph { position: absolute; aspect-ratio: 1; color: color-mix(in srgb, var(--ink) 38%, var(--paper)); }
</style>
