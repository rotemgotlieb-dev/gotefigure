---
// V2 product card (owner mandate + research): SQUARE hand-drawn ink frame (boiling),
// uniform 1:1 image well on paper, name + machine-steady mono price, hover = second
// image crossfade. No ovals, no era chips, no "from" unless prices actually differ.
import { Image } from 'astro:assets';
import RoughFrame from './RoughFrame.astro';
import type { Product } from '../lib/commerce';
import { getPhoto } from '../lib/photos';

interface Props { product: Product; eager?: boolean }
const { product: p, eager = false } = Astro.props;

const photoName = p.artSrc.startsWith('photo:') ? p.artSrc.slice(6) : undefined;
const facePhoto = photoName ? getPhoto(photoName) : undefined;
const hoverPhoto = p.lifestylePhoto && p.lifestylePhoto !== photoName ? getPhoto(p.lifestylePhoto) : undefined;
const pricesDiffer = new Set(p.variants.map((v) => v.price)).size > 1;
const priceLabel = pricesDiffer ? `from $${p.price}` : `$${p.price}`;
// the OG cameo card gets live googly pupils (measured registration; his art, watching you browse)
const hasLiveEyes = p.artSrc === '/art/rabbit-cameo.webp';
---
<a href={`/shop/${p.slug}/`} class="card" aria-label={`${p.name}, ${p.available ? priceLabel : 'sold out'}`}>
  <div class="well" style={`view-transition-name: art-${p.slug}`}>
    {facePhoto ? (
      <Image src={facePhoto} alt="" widths={[400, 700]} sizes="(max-width: 640px) 46vw, 360px" loading={eager ? 'eager' : 'lazy'} class="face face--photo" />
    ) : (
      <img src={p.artSrc} alt="" loading={eager ? 'eager' : 'lazy'} class="face face--art" />
    )}
    {hoverPhoto && (
      <Image src={hoverPhoto} alt="" widths={[400, 700]} sizes="(max-width: 640px) 46vw, 360px" loading="lazy" class="face face--hover" />
    )}
    {hasLiveEyes && (
      <svg data-pupils viewBox="0 0 800 1600" class="live-eyes" aria-hidden="true">
        <g id="eye-l"><circle id="pupil-l" class="pupil" cx="296" cy="968" r="40" fill="#0d0d0d"/><circle cx="312" cy="946" r="12" fill="#fff"/></g>
        <g id="eye-r"><circle id="pupil-r" class="pupil" cx="448" cy="948" r="30" fill="#0d0d0d"/><circle cx="459" cy="932" r="9" fill="#fff"/></g>
      </svg>
    )}
    {!p.available && <span class="soldout" aria-hidden="true">sold out</span>}
    <RoughFrame seed={p.slug} w={300} h={300} />
  </div>
  <div class="meta">
    <h3 class="name">{p.name}</h3>
    <p class="price mono">{p.available ? priceLabel : 'sold out'}</p>
  </div>
</a>

<style>
  .card { display: block; text-decoration: none; outline-offset: 6px; }
  .well {
    position: relative;
    aspect-ratio: 1;
    background: var(--paper);
    overflow: hidden;
    transition: transform var(--dur-quick) var(--ease-arrive);
  }
  .card:nth-of-type(odd) .well { transform: rotate(-0.35deg); }
  .card:hover .well, .card:focus-visible .well { transform: rotate(0deg) translateY(-3px); }

  .face { position: absolute; inset: 8px; width: calc(100% - 16px); height: calc(100% - 16px); object-fit: cover; }
  .face--art { object-fit: contain; padding: 9%; }
  .face--hover { opacity: 0; transition: opacity var(--dur-moment) var(--ease-arrive); }
  @media (hover: hover) {
    .card:hover .face--hover, .card:focus-visible .face--hover { opacity: 1; }
  }

  /* match the contained art's box: same inset as .face--art incl. its 9% padding;
     viewBox letterboxing (meet) then mirrors object-fit:contain — eye registration holds */
  .live-eyes { position: absolute; inset: calc(8px + 8.5%); width: auto; height: auto; pointer-events: none; }
  .live-eyes circle { transform-box: fill-box; }

  .soldout {
    position: absolute; top: 10px; right: 8px;
    font-family: var(--font-hand);
    font-size: 0.8rem;
    background: var(--paper);
    border: 1.5px solid var(--ink);
    padding: 2px 10px;
    transform: rotate(4deg);
  }

  .meta { display: flex; justify-content: space-between; align-items: baseline; gap: var(--s-3); padding: var(--s-3) 2px 0; }
  .name { font-family: var(--font-ui); font-size: var(--text-sm); font-weight: 600; line-height: 1.3; }
  .price { font-size: var(--text-sm); flex: none; }
</style>
