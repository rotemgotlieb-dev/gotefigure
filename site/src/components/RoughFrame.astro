---
// The hand-drawn frame (V2 card bones): build-time rough.js rectangle, 3 boil variants,
// square corners, ink stroke. Stretches over its parent; stroke width stays true.
import { roughRectPaths, seedFrom } from '../lib/rough-frame';

interface Props { seed: string; w?: number; h?: number; roughness?: number; strokeWidth?: number; class?: string }
const { seed, w = 300, h = 380, roughness = 1.5, strokeWidth = 2, class: cls } = Astro.props;
const variants = roughRectPaths({ w, h, seed: seedFrom(seed), roughness, strokeWidth });
---
<svg
  class:list={['rough-frame', cls]}
  viewBox={`0 0 ${w} ${h}`}
  preserveAspectRatio="none"
  aria-hidden="true"
  focusable="false"
>
  {variants.map((paths, i) => (
    <g class={`boil-v boil-v${i}`}>
      {paths.map((d) => (
        <path d={d} fill="none" stroke="currentColor" stroke-width={strokeWidth} stroke-linecap="round" vector-effect="non-scaling-stroke" />
      ))}
    </g>
  ))}
</svg>

<style>
  .rough-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    color: var(--ink);
    overflow: visible;
  }
  /* boil: exactly one variant visible; animations/boil.ts steps the page-level counter.
     Static fallback (no JS / reduced motion): variant 0 shows. */
  .boil-v { display: none; }
  .boil-v0 { display: block; }
  :global(html[data-boil='1']) .boil-v { display: none; }
  :global(html[data-boil='1']) .boil-v1 { display: block; }
  :global(html[data-boil='2']) .boil-v { display: none; }
  :global(html[data-boil='2']) .boil-v2 { display: block; }
  :global(html[data-boil='1']) .boil-v0 { display: none; }
  :global(html[data-boil='2']) .boil-v0 { display: none; }
</style>
