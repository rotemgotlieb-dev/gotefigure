---
// Minimal full-viewport shell for /after-hours — the pre-launch "dark salon" takeover.
// Deliberately NOT the store Layout (no header/announce/footer/cart): the mock is a full-bleed
// scene with its own header. Shared by the desktop (this branch) and mobile (parallel) builds.
import { ClientRouter } from 'astro:transitions';
import '../styles/tokens.css';       // --ah-* palette + font tokens
import '../styles/after-hours.css';  // @font-face for the three display fonts

interface Props { title: string; description: string; }
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0906" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
  </head>
  <body>
    <slot />
    <script>
      import { initAfterHours, destroyAfterHours } from '../animations/after-hours';
      // Bound on every page-load (fires on first paint too with ClientRouter) and torn down
      // before each swap, so the rAF torch never duplicates or leaks across navigations.
      document.addEventListener('astro:page-load', initAfterHours);
      document.addEventListener('astro:before-swap', destroyAfterHours);
    </script>
    <style is:global>
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; overflow: hidden; }
      body {
        background: var(--ah-black);
        color: var(--ah-ink);
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--ah-ink); color: var(--ah-card); }
      img { display: block; }
    </style>
  </body>
</html>
