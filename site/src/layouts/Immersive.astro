---
// Chromeless full-screen shell for immersive pages (After Hours salon). No site Header /
// SatchelDrawer / flood / site-grain: the page owns its whole frame. Same fonts + tokens +
// base + ClientRouter as Layout. Lean motion bootstrap (core + the one page module) keeps a
// direct load console-clean instead of pulling the full store motion set.
import { ClientRouter } from 'astro:transitions';
import '@fontsource/nanum-brush-script';
import '@fontsource/reenie-beanie';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '../styles/tokens.css';
import '../styles/base.css';

interface Props { title: string; description: string; themeColor?: string; }
const { title, description, themeColor = '#0C0906' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
  </head>
  <body class="immersive">
    <a href="#main" class="skip-link">Skip to content</a>
    <main id="main">
      <slot />
    </main>
    <script>
      import { startMotion } from '../animations/core';
      import '../animations/after-hours';
      startMotion();
    </script>
    <style is:global>
      body.immersive { background: var(--ah-night); overflow: hidden; min-height: 100dvh; }
    </style>
  </body>
</html>
