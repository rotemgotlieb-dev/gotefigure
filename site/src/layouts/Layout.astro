---
// HTML shell for every page. Head/meta, ClientRouter (view transitions, §7.3), header/footer.
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/shantell-sans/full.css'; // full = INFM/BNCE axes (the hand voice's informality dial)
import '../styles/tokens.css';
import '../styles/base.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CartDrawer from '../components/CartDrawer.astro';

interface Props { title: string; description: string; }
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Pre-launch: the shop is closed. Every store page bounces to the After Hours door (/) unless
      // the author has unlocked preview via the code on the door (localStorage 'gf-preview'). Runs
      // pre-paint so the closed store never flashes.
      try { if (!localStorage.getItem('gf-preview')) location.replace('/'); } catch (e) {}
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F2F1EA" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      // pre-paint intro gate: overlay shows only on first home visit, motion-OK sessions (§7.1)
      if (location.pathname === '/' && !sessionStorage.getItem('gf-intro-seen')
        && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.dataset.intro = '1';
      }
    </script>
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <p class="announce mono caps">hand-drawn in California <span aria-hidden="true">✶</span> tees print to order <span aria-hidden="true">✶</span> posters &amp; stickers ship in 2–4 days</p>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <div transition:persist="cart" style="position: relative; z-index: var(--z-drawer);">
      <CartDrawer />
    </div>
    <!-- Ink flood page-transition overlay (§7.2 Phase 2): persists across swaps; driven by animations/flood-nav -->
    <svg class="gf-flood" transition:persist="flood" aria-hidden="true" preserveAspectRatio="none"
      style="position:fixed;inset:0;width:100%;height:100%;z-index:9000;pointer-events:none;opacity:0;display:block;will-change:opacity">
      <path class="gf-flood-path" d="" fill="#111111"></path>
    </svg>
    <script>
      import '../animations/index';
    </script>
    <style>
      .announce {
        text-align: center;
        font-size: 0.72rem;
        padding: 9px var(--s-4);
        background: var(--ink);
        color: var(--paper);
        margin: 0;
      }
      .announce span { color: var(--amber); }
    </style>
  </body>
</html>
