---
// HTML shell — v3 (Fable 5 store design). Header + satchel drawer + flood overlay persist;
// grain overlay; fonts: Nanum Brush (display) / Kalam + Reenie Beanie (hand skin) / Space Mono.
import { ClientRouter } from 'astro:transitions';
import '@fontsource/nanum-brush-script';
import '@fontsource/kalam/300.css';
import '@fontsource/kalam/400.css';
import '@fontsource/kalam/700.css';
import '@fontsource/reenie-beanie';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '../styles/tokens.css';
import '../styles/base.css';
import Header from '../components/Header.astro';
import SatchelDrawer from '../components/SatchelDrawer.astro';

// `gated`: only the server-gated pages (store / piece / vault, prerender=false) set this.
// It is what lets the satchel drawer serialize the catalog payload (names/prices/art) into
// the page. Public prerendered pages (about, 404, info/*) MUST leave it false, or the full
// pre-launch catalog bakes into static HTML anyone can fetch (S4 adversarial review,
// CRITICAL finding, 2026-07-10). Enforced post-build by scripts/dist-lint.mjs.
interface Props { title: string; description: string; dark?: boolean; gated?: boolean; }
const { title, description, dark = false, gated = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Pre-launch: the shop is closed. Every store page bounces to the After Hours door (/) unless
      // the author has unlocked preview via the code on the door (localStorage 'gf-store-open'). Runs
      // pre-paint so the closed store never flashes.
      try { if (!localStorage.getItem('gf-store-open')) location.replace('/'); } catch (e) {}
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F7F5F0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      // pre-paint arrival gate: first home visit, motion-OK sessions only (design gf3-intro)
      if (location.pathname === '/' && !sessionStorage.getItem('gf3-intro')
        && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.dataset.arrival = '1';
      }
    </script>
    <ClientRouter />
  </head>
  <body class:list={[{ 'page-dark': dark }]}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <div transition:persist="cart" style="position: relative; z-index: var(--z-drawer);">
      <SatchelDrawer catalog={gated} />
    </div>
    <!-- flood-to-navigate overlay — persists across swaps; driven by animations/flood-nav -->
    <svg class="gf-flood" transition:persist="flood" aria-hidden="true" preserveAspectRatio="none"
      style="position:fixed;inset:0;width:100vw;height:100dvh;z-index:9000;pointer-events:none;opacity:0;display:block;will-change:opacity">
      <path class="gf-flood-path" d="" fill="#16130F"></path>
    </svg>
    <div class="gf-grain" aria-hidden="true"></div>
    <script>
      import '../animations/index';
    </script>
    <style is:global>
      body.page-dark { background: var(--ink); }
    </style>
  </body>
</html>
